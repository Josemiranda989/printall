# === PocketBase ===
# URL interna para SSR (Docker network — no cambiar en prod)
POCKETBASE_URL=http://pocketbase:8090

# URL pública para imágenes (la que ve el browser, se inlina al buildear)
PUBLIC_POCKETBASE_URL=https://your-pocketbase-domain.com

# === WhatsApp ===
# Número del negocio en formato internacional (sin + ni espacios)
PUBLIC_WHATSAPP_NUMBER=5490000000000
