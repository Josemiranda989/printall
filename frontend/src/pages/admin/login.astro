---
import AdminLayout from "../../layouts/AdminLayout.astro";
import {
  loginAdmin,
  setAdminCookie,
  readAdminCookie,
  verifyAdminToken,
} from "../../lib/admin-auth";

const url = new URL(Astro.request.url);
const rawRedirect = url.searchParams.get("redirect") ?? "/admin/productos";
const safeRedirect = rawRedirect.startsWith("/admin") ? rawRedirect : "/admin/productos";

const existing = readAdminCookie(Astro.cookies);
if (existing && (await verifyAdminToken(existing))) {
  return Astro.redirect(safeRedirect);
}

let error: string | null = null;
let emailValue = "";

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const email = String(form.get("email") ?? "").trim();
  const password = String(form.get("password") ?? "");
  emailValue = email;

  if (!email || !password) {
    error = "Email y contraseña son requeridos.";
  } else {
    const auth = await loginAdmin(email, password);
    if (!auth) {
      error = "Credenciales inválidas.";
    } else {
      setAdminCookie(Astro.cookies, auth.token);
      return Astro.redirect(safeRedirect);
    }
  }
}
---

<AdminLayout title="Login">
  <div class="min-h-[70vh] flex items-center justify-center">
    <div class="w-full max-w-sm">
      <div class="text-center mb-6">
        <h1 class="font-display text-3xl mb-1">Admin</h1>
        <p class="text-sm text-gray-600">Acceso al panel de Print All</p>
      </div>

      <form
        method="POST"
        class="bg-white border-2 border-brand rounded-lg p-6 space-y-4 shadow-[4px_4px_0_var(--color-brand)]"
      >
        {error && (
          <div class="border-2 border-red-500 bg-red-50 text-red-800 px-3 py-2 rounded-md text-sm">
            {error}
          </div>
        )}

        <label class="block">
          <span class="text-sm font-medium">Email</span>
          <input
            type="email"
            name="email"
            value={emailValue}
            required
            autocomplete="username"
            class="mt-1 block w-full border-2 border-brand rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-accent"
          />
        </label>

        <label class="block">
          <span class="text-sm font-medium">Contraseña</span>
          <input
            type="password"
            name="password"
            required
            autocomplete="current-password"
            class="mt-1 block w-full border-2 border-brand rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-accent"
          />
        </label>

        <button
          type="submit"
          class="w-full bg-accent text-white font-medium px-4 py-2.5 rounded-md hover:bg-accent-hover transition-colors"
        >
          Entrar
        </button>
      </form>

      <p class="text-center text-xs text-gray-500 mt-4">
        Usa las credenciales de superuser de PocketBase.
      </p>
    </div>
  </div>
</AdminLayout>
