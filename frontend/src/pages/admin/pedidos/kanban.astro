---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import OrderPriorityBadge from "../../../components/admin/OrderPriorityBadge.astro";
import MaterialColorChip from "../../../components/admin/MaterialColorChip.astro";
import OrderProgressBar from "../../../components/admin/OrderProgressBar.astro";
import {
  buildOrdersFilter,
  hasFilters,
  parseSearchParams,
} from "../../../lib/admin-orders-filter";
import { fetchAllClients } from "../../../lib/admin-clients";
import {
  COLOR_LABELS,
  COLOR_VALUES,
  MATERIAL_LABELS,
  MATERIAL_VALUES,
  ORDER_STATUS_LABELS,
  ORDER_STATUS_VALUES,
  PRIORITY_LABELS,
  PRIORITY_VALUES,
  type Order,
  type OrderStatus,
} from "../../../lib/types";

const pb = Astro.locals.adminPB!;

const filters = parseSearchParams(Astro.url.searchParams);
const activeFilters = hasFilters(filters);
const pbFilter = buildOrdersFilter(filters);

const allClients = await fetchAllClients(pb);

// Cargar TODOS los pedidos que pasan el filtro (kanban no tiene paginación)
// pero limitamos a 500 por seguridad. Si crece más, conviene cargar por columna.
const allOrders = (await pb.collection("orders").getFullList({
  filter: pbFilter,
  sort: "-priority,delivery_date,-created",
  batch: 500,
})) as unknown as Order[];

// Agrupar por estado
const byStatus = new Map<OrderStatus, Order[]>();
for (const s of ORDER_STATUS_VALUES) byStatus.set(s, []);
for (const o of allOrders) {
  byStatus.get(o.status)?.push(o);
}

const today = new Date();
today.setHours(0, 0, 0, 0);

function isOverdue(o: Order): boolean {
  if (!o.delivery_date) return false;
  const d = new Date(o.delivery_date);
  if (isNaN(d.getTime())) return false;
  return (
    d < today &&
    o.status !== "completed" &&
    o.status !== "delivered" &&
    o.status !== "cancelled"
  );
}

function fmtShortDate(iso: string | null | undefined): string {
  if (!iso) return "—";
  const d = new Date(iso);
  if (isNaN(d.getTime())) return "—";
  const dd = String(d.getDate()).padStart(2, "0");
  const mm = String(d.getMonth() + 1).padStart(2, "0");
  return `${dd}/${mm}`;
}

const inputClass =
  "mt-1 w-full rounded border-2 border-brand/40 px-3 py-2 text-sm focus:border-brand focus:outline-none bg-white";
const selectClass =
  "mt-1 w-full rounded border-2 border-brand/40 px-3 py-2 text-sm focus:border-brand focus:outline-none bg-white cursor-pointer";
const labelSpanClass =
  "text-xs font-medium uppercase tracking-wider text-brand/70";

const tabBaseClass =
  "px-3 py-1.5 border-2 rounded-md text-sm font-medium transition-colors";
const tabActiveClass = "bg-brand text-white border-brand";
const tabInactiveClass =
  "border-brand/30 text-brand hover:bg-brand hover:text-white";

// Color del header de cada columna por estado
const COLUMN_HEADER_COLORS: Record<OrderStatus, string> = {
  pending: "bg-red-100 text-red-800 border-red-300",
  in_progress: "bg-amber-100 text-amber-800 border-amber-300",
  completed: "bg-emerald-100 text-emerald-800 border-emerald-300",
  delivered: "bg-blue-100 text-blue-800 border-blue-300",
  cancelled: "bg-gray-100 text-gray-600 border-gray-300",
};
---

<AdminLayout title="Pedidos · Kanban">
  <div class="flex items-center justify-between gap-3 mb-5 flex-wrap">
    <h1 class="font-display text-2xl sm:text-3xl">Pedidos</h1>
    <a
      href="/admin/pedidos/nuevo"
      class="bg-accent text-white font-medium px-3 sm:px-4 py-2 rounded-md hover:bg-accent-hover transition-colors text-sm shrink-0 whitespace-nowrap"
    >
      <span class="sm:hidden">+ Nuevo</span>
      <span class="hidden sm:inline">+ Nuevo pedido</span>
    </a>
  </div>

  <div class="flex items-center gap-2 mb-5 flex-wrap">
    <a href="/admin/pedidos" class={`${tabBaseClass} ${tabInactiveClass}`}>📋 Tabla</a>
    <a href="/admin/pedidos/kanban" class={`${tabBaseClass} ${tabActiveClass}`}>📊 Kanban</a>
    <a href="/admin/pedidos/calendario" class={`${tabBaseClass} ${tabInactiveClass}`}>📅 Calendario</a>
  </div>

  {/* ─── Filtros (colapsable, mismos que tabla; sin status porque las columnas SON el status) ─── */}
  <details
    class="bg-white border-2 border-brand rounded-lg mb-5 shadow-[4px_4px_0_var(--color-brand)] overflow-hidden group"
    open={activeFilters}
  >
    <summary class="cursor-pointer px-4 py-3 flex items-center justify-between gap-2 hover:bg-surface/50 transition-colors select-none list-none">
      <span class="flex items-center gap-2 font-medium text-sm">
        <span class="text-brand/70">🔎</span>
        Filtros
        {activeFilters && (
          <span class="text-xs bg-accent text-white px-2 py-0.5 rounded-full font-mono">
            activos
          </span>
        )}
      </span>
      <span class="text-xs text-gray-400 group-open:hidden">▼ Mostrar</span>
      <span class="text-xs text-gray-400 hidden group-open:inline">▲ Ocultar</span>
    </summary>
  <form
    method="GET"
    class="px-4 pb-4 border-t-2 border-brand/10"
  >
    <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-3 items-end pt-4">
      <label class="block">
        <span class={labelSpanClass}>Buscar</span>
        <input
          type="text"
          name="q"
          value={filters.q ?? ""}
          placeholder="Proyecto, cliente…"
          class={inputClass}
        />
      </label>

      <label class="block">
        <span class={labelSpanClass}>Prioridad</span>
        <select name="priority" onchange="this.form.submit()" class={selectClass}>
          <option value="">Todas</option>
          {PRIORITY_VALUES.map((p) => (
            <option value={p} selected={filters.priority === p}>
              {PRIORITY_LABELS[p]}
            </option>
          ))}
        </select>
      </label>

      <label class="block">
        <span class={labelSpanClass}>Pago</span>
        <select name="paid" onchange="this.form.submit()" class={selectClass}>
          <option value="">Todos</option>
          <option value="yes" selected={filters.paid === "yes"}>Pagados</option>
          <option value="no" selected={filters.paid === "no"}>Sin pagar</option>
        </select>
      </label>

      <label class="block">
        <span class={labelSpanClass}>Material</span>
        <select name="material" onchange="this.form.submit()" class={selectClass}>
          <option value="">Todos</option>
          {MATERIAL_VALUES.map((m) => (
            <option value={m} selected={filters.material === m}>
              {MATERIAL_LABELS[m]}
            </option>
          ))}
        </select>
      </label>

      <label class="block">
        <span class={labelSpanClass}>Color</span>
        <select name="color" onchange="this.form.submit()" class={selectClass}>
          <option value="">Todos</option>
          {COLOR_VALUES.map((c) => (
            <option value={c} selected={filters.color === c}>
              {COLOR_LABELS[c]}
            </option>
          ))}
        </select>
      </label>

      <label class="block">
        <span class={labelSpanClass}>Cliente</span>
        <select name="client" onchange="this.form.submit()" class={selectClass}>
          <option value="">Todos</option>
          {allClients.map((c) => (
            <option value={c.id} selected={filters.client === c.id}>
              {c.name}
            </option>
          ))}
        </select>
      </label>
    </div>

    <div class="flex flex-wrap items-center justify-between gap-3 mt-3">
      <button type="submit" class="px-4 py-2 bg-accent text-white rounded-md hover:bg-accent-hover transition-colors text-sm font-medium w-full sm:w-auto">
        Buscar
      </button>
      {activeFilters && (
        <a href="/admin/pedidos/kanban" class="text-sm text-gray-500 hover:text-brand underline">
          Limpiar filtros
        </a>
      )}
    </div>
  </form>
  </details>

  <p class="text-xs text-gray-500 mb-3 italic">
    Arrastrá una tarjeta a otra columna para cambiar su estado.
  </p>

  {/* ─── Error global del kanban ─── */}
  <div
    id="kanban-error"
    class="hidden border-2 border-red-500 bg-red-50 text-red-800 px-3 py-2 rounded-md text-sm mb-4"
    role="alert"
  ></div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3">
    {ORDER_STATUS_VALUES.map((status) => {
      const items = byStatus.get(status) ?? [];
      return (
        <div class="bg-surface/50 border-2 border-brand/20 rounded-lg flex flex-col min-h-[300px]">
          <header
            class={`px-3 py-2 border-b-2 rounded-t-md font-medium text-sm ${COLUMN_HEADER_COLORS[status]}`}
          >
            <div class="flex items-center justify-between">
              <span>{ORDER_STATUS_LABELS[status]}</span>
              <span class="text-xs opacity-75 font-mono" data-col-count>({items.length})</span>
            </div>
          </header>
          <div
            class="kanban-col p-2 space-y-2 flex-1 overflow-y-auto"
            data-status={status}
          >
            {items.map((o) => {
              const overdue = isOverdue(o);
              return (
                <a
                  href={`/admin/pedidos/${o.id}`}
                  class="kanban-card block bg-white border-2 border-brand rounded-md p-3 shadow-sm hover:shadow-md transition-shadow cursor-grab active:cursor-grabbing"
                  data-order-id={o.id}
                >
                  <div class="flex items-start justify-between gap-2 mb-1.5">
                    <p class="font-mono text-xs text-gray-500">{o.order_number || o.id.slice(-6)}</p>
                    <OrderPriorityBadge priority={o.priority} />
                  </div>
                  <p class="font-medium text-sm leading-tight mb-1">{o.project_name}</p>
                  <p class="text-xs text-gray-600 mb-2">{o.customer_name}</p>
                  <div class="flex items-center justify-between gap-2 mb-2">
                    <MaterialColorChip material={o.material} color={o.color} />
                    {o.is_paid && (
                      <span class="text-xs text-emerald-700 font-medium">✓ Pago</span>
                    )}
                  </div>
                  <OrderProgressBar
                    done={o.units_done}
                    total={o.units_ordered}
                    compact
                    overdue={overdue}
                  />
                  {o.delivery_date && (
                    <p class={`text-xs mt-2 ${overdue ? "text-red-600 font-medium" : "text-gray-500"}`}>
                      {overdue && "⚠ "}Entrega: {fmtShortDate(o.delivery_date)}
                    </p>
                  )}
                </a>
              );
            })}
            {items.length === 0 && (
              <p class="text-xs text-gray-400 italic text-center py-4">Vacío</p>
            )}
          </div>
        </div>
      );
    })}
  </div>
</AdminLayout>

<script>
  import Sortable from "sortablejs";

  const errorEl = document.getElementById("kanban-error")!;
  function showError(msg: string) {
    errorEl.textContent = msg;
    errorEl.classList.remove("hidden");
    setTimeout(() => errorEl.classList.add("hidden"), 4000);
  }

  function updateCount(col: HTMLElement) {
    const card = col.querySelectorAll(".kanban-card").length;
    const header = col.parentElement?.querySelector("[data-col-count]");
    if (header) header.textContent = `(${card})`;
  }

  document.querySelectorAll<HTMLElement>(".kanban-col").forEach((col) => {
    new Sortable(col, {
      animation: 150,
      ghostClass: "opacity-50",
      group: "kanban-orders",
      onEnd: async (evt) => {
        const item = evt.item as HTMLElement;
        const fromCol = evt.from as HTMLElement;
        const toCol = evt.to as HTMLElement;

        if (fromCol === toCol) return; // mismo column = solo reorden, no hace nada en backend

        const orderId = item.dataset.orderId;
        const newStatus = toCol.dataset.status;

        if (!orderId || !newStatus) {
          showError("Falta data del pedido. Recargá la página.");
          fromCol.appendChild(item);
          return;
        }

        if (newStatus === "cancelled") {
          if (!confirm("¿Marcar este pedido como cancelado?")) {
            fromCol.appendChild(item);
            return;
          }
        }

        try {
          const res = await fetch(`/admin/api/orders/${orderId}/status`, {
            method: "PATCH",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ status: newStatus }),
          });
          const data = (await res.json()) as { ok: boolean; error?: string };
          if (!res.ok || !data.ok) {
            fromCol.appendChild(item);
            showError(data.error ?? "No se pudo cambiar el estado.");
          }
        } catch {
          fromCol.appendChild(item);
          showError("Error de red. Reintentá.");
        }

        updateCount(fromCol);
        updateCount(toCol);
      },
    });
  });
</script>
