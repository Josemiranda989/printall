---
import AdminLayout from "../../layouts/AdminLayout.astro";
import OrderStatusBadge from "../../components/admin/OrderStatusBadge.astro";
import MaterialColorChip from "../../components/admin/MaterialColorChip.astro";
import { MATERIAL_LABELS, type Order } from "../../lib/types";

const pb = Astro.locals.adminPB!;

// ─── Helpers de fecha ────────────────────────────────────────────────────
function pad(n: number): string {
  return String(n).padStart(2, "0");
}
function ymd(d: Date): string {
  return d.getFullYear() + "-" + pad(d.getMonth() + 1) + "-" + pad(d.getDate());
}

const now = new Date();
const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
const in7Days = new Date(today);
in7Days.setDate(in7Days.getDate() + 7);

const todayStr = ymd(today);
const in7DaysStr = ymd(in7Days);

// Mes actual (rango completo)
const firstDayCurrent = new Date(now.getFullYear(), now.getMonth(), 1);
const lastDayCurrent = new Date(now.getFullYear(), now.getMonth() + 1, 0);
const firstDayPrev = new Date(now.getFullYear(), now.getMonth() - 1, 1);
const lastDayPrev = new Date(now.getFullYear(), now.getMonth(), 0);

const monthCurrentFilter =
  `delivery_date >= "${ymd(firstDayCurrent)} 00:00:00" && ` +
  `delivery_date <= "${ymd(lastDayCurrent)} 23:59:59" && ` +
  `status = "delivered"`;
const monthPrevFilter =
  `delivery_date >= "${ymd(firstDayPrev)} 00:00:00" && ` +
  `delivery_date <= "${ymd(lastDayPrev)} 23:59:59" && ` +
  `status = "delivered"`;

// ─── Queries operativas (Sección 1: Hoy) ────────────────────────────────
// requestKey: null deshabilita la auto-cancelación del SDK PB. Necesario
// cuando hacés varias queries en paralelo a la misma collection — sin esto
// el SDK las considera duplicadas y cancela todas menos la última.
const [pendingRes, inProgressRes, overdueRes, upcomingRes] = await Promise.all([
  pb.collection("orders").getList(1, 1, {
    filter: 'status = "pending"',
    fields: "id",
    requestKey: null,
  }),
  pb.collection("orders").getList(1, 1, {
    filter: 'status = "in_progress"',
    fields: "id",
    requestKey: null,
  }),
  pb.collection("orders").getList(1, 1, {
    filter:
      `delivery_date != "" && delivery_date < "${todayStr} 00:00:00" && ` +
      `status != "delivered" && status != "cancelled"`,
    fields: "id",
    requestKey: null,
  }),
  // Próximas entregas (7 días) — pedimos la lista completa para reusar abajo
  pb.collection("orders").getList(1, 50, {
    filter:
      `delivery_date >= "${todayStr} 00:00:00" && ` +
      `delivery_date <= "${in7DaysStr} 23:59:59" && ` +
      `status != "delivered" && status != "cancelled"`,
    sort: "delivery_date",
    requestKey: null,
  }),
]);

const pendingCount = pendingRes.totalItems;
const inProgressCount = inProgressRes.totalItems;
const overdueCount = overdueRes.totalItems;
const upcomingItems = upcomingRes.items as unknown as Order[];
const upcomingCount = upcomingRes.totalItems;

// ─── Queries del mes (Sección 2) ────────────────────────────────────────
const [monthCurrentList, monthPrevList, toCollectRes] = await Promise.all([
  pb.collection("orders").getFullList({
    filter: monthCurrentFilter,
    fields: "id,unit_price,units_done,units_ordered,material",
    batch: 500,
    requestKey: null,
  }),
  pb.collection("orders").getFullList({
    filter: monthPrevFilter,
    fields: "id,unit_price,units_done,units_ordered",
    batch: 500,
    requestKey: null,
  }),
  // Sección 4: por cobrar
  pb.collection("orders").getList(1, 50, {
    filter: 'status = "delivered" && is_paid = false',
    sort: "-created",
    requestKey: null,
  }),
]);

// Agregaciones del mes actual
function sumRevenue(list: { unit_price?: number; units_done?: number; units_ordered?: number }[]): number {
  return list.reduce((acc, o) => {
    const price = Number(o.unit_price) || 0;
    // Si units_done = 0 pero el pedido está delivered, asumimos units_ordered.
    const units = Number(o.units_done) || Number(o.units_ordered) || 0;
    return acc + price * units;
  }, 0);
}

const monthCurrentCount = monthCurrentList.length;
const monthCurrentRevenue = sumRevenue(monthCurrentList as unknown as { unit_price?: number; units_done?: number; units_ordered?: number }[]);
const monthCurrentAvg =
  monthCurrentCount > 0 ? monthCurrentRevenue / monthCurrentCount : 0;

const monthPrevCount = monthPrevList.length;
const monthPrevRevenue = sumRevenue(monthPrevList as unknown as { unit_price?: number; units_done?: number; units_ordered?: number }[]);
const monthPrevAvg = monthPrevCount > 0 ? monthPrevRevenue / monthPrevCount : 0;

// Material top del mes (agrupar por material y contar)
const materialCounts = new Map<string, number>();
for (const o of monthCurrentList as unknown as { material?: string }[]) {
  const m = (o.material || "").trim();
  if (!m) continue;
  materialCounts.set(m, (materialCounts.get(m) || 0) + 1);
}
let topMaterial: { name: string; count: number } | null = null;
for (const [name, count] of materialCounts) {
  if (!topMaterial || count > topMaterial.count) {
    topMaterial = { name, count };
  }
}

const toCollectItems = toCollectRes.items as unknown as Order[];
const toCollectCount = toCollectRes.totalItems;

// Delta vs mes anterior — devuelve null si no comparable
function delta(current: number, prev: number): { pct: number; isUp: boolean } | null {
  if (prev <= 0) return null;
  const diff = ((current - prev) / prev) * 100;
  return { pct: Math.abs(Math.round(diff)), isUp: diff >= 0 };
}

const deltaCount = delta(monthCurrentCount, monthPrevCount);
const deltaRevenue = delta(monthCurrentRevenue, monthPrevRevenue);
const deltaAvg = delta(monthCurrentAvg, monthPrevAvg);

// ─── Helpers de formato ─────────────────────────────────────────────────
function fmtArs(n: number): string {
  return "$" + Math.round(n).toLocaleString("es-AR");
}
function fmtDeliveryDate(iso: string | null | undefined): string {
  if (!iso) return "—";
  const d = new Date(iso);
  if (isNaN(d.getTime())) return "—";
  return pad(d.getDate()) + "/" + pad(d.getMonth() + 1);
}
function isOverdue(o: Order): boolean {
  if (!o.delivery_date) return false;
  const d = new Date(o.delivery_date);
  if (isNaN(d.getTime())) return false;
  return (
    d < today &&
    o.status !== "delivered" &&
    o.status !== "completed" &&
    o.status !== "cancelled"
  );
}

// Nombre del mes capitalizado para el header
const monthName = now.toLocaleDateString("es-AR", { month: "long", year: "numeric" });
const todayLabel = now.toLocaleDateString("es-AR", {
  weekday: "long",
  day: "numeric",
  month: "long",
});

// ─── Estilos compartidos ────────────────────────────────────────────────
const cardClass =
  "bg-white border-2 border-brand rounded-lg p-4 sm:p-5 shadow-[4px_4px_0_var(--color-brand)]";
const kpiClass =
  "block " + cardClass +
  " hover:shadow-[6px_6px_0_var(--color-brand)] hover:translate-y-[-2px] transition-all cursor-pointer";
---

<AdminLayout title="Dashboard">
  <div class="mb-5">
    <h1 class="font-display text-2xl sm:text-3xl">Dashboard</h1>
    <p class="text-xs sm:text-sm text-gray-500 mt-1 capitalize">{todayLabel}</p>
  </div>

  {/* ─── Sección 1: Hoy (operativo) ─── */}
  <section class="mb-6">
    <h2 class="text-xs uppercase tracking-wider text-brand/60 font-medium mb-2">Hoy</h2>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
      <a href="/admin/pedidos?status=pending" class={kpiClass}>
        <p class="text-xs text-gray-500 mb-1">🟡 Pendientes</p>
        <p class="text-3xl font-display">{pendingCount}</p>
      </a>
      <a href="/admin/pedidos?status=in_progress" class={kpiClass}>
        <p class="text-xs text-gray-500 mb-1">🔵 En proceso</p>
        <p class="text-3xl font-display">{inProgressCount}</p>
      </a>
      <a
        href={`/admin/pedidos?delivery_to=${todayStr}`}
        class={kpiClass + (overdueCount > 0 ? " ring-2 ring-red-400" : "")}
      >
        <p class="text-xs text-gray-500 mb-1">🔴 Atrasados</p>
        <p class={"text-3xl font-display " + (overdueCount > 0 ? "text-red-600" : "")}>
          {overdueCount}
        </p>
      </a>
      <a href={`/admin/pedidos?delivery_from=${todayStr}&delivery_to=${in7DaysStr}`} class={kpiClass}>
        <p class="text-xs text-gray-500 mb-1">📅 Próximos 7 días</p>
        <p class="text-3xl font-display">{upcomingCount}</p>
      </a>
    </div>
  </section>

  {/* ─── Sección 2: Este mes (negocio) ─── */}
  <section class="mb-6">
    <h2 class="text-xs uppercase tracking-wider text-brand/60 font-medium mb-2 capitalize">
      {monthName}
    </h2>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
      <div class={cardClass}>
        <p class="text-xs text-gray-500 mb-1">Pedidos entregados</p>
        <p class="text-3xl font-display">{monthCurrentCount}</p>
        {deltaCount !== null && (
          <p class={`text-xs mt-1 font-medium ${deltaCount.isUp ? "text-emerald-700" : "text-red-600"}`}>
            {deltaCount.isUp ? "↑" : "↓"} {deltaCount.pct}% vs mes anterior
          </p>
        )}
      </div>
      <div class={cardClass}>
        <p class="text-xs text-gray-500 mb-1">Ingresos</p>
        <p class="text-3xl font-display font-mono">{fmtArs(monthCurrentRevenue)}</p>
        {deltaRevenue !== null && (
          <p class={`text-xs mt-1 font-medium ${deltaRevenue.isUp ? "text-emerald-700" : "text-red-600"}`}>
            {deltaRevenue.isUp ? "↑" : "↓"} {deltaRevenue.pct}% vs mes anterior
          </p>
        )}
      </div>
      <div class={cardClass}>
        <p class="text-xs text-gray-500 mb-1">Ticket promedio</p>
        <p class="text-3xl font-display font-mono">
          {monthCurrentCount > 0 ? fmtArs(monthCurrentAvg) : "—"}
        </p>
        {deltaAvg !== null && (
          <p class={`text-xs mt-1 font-medium ${deltaAvg.isUp ? "text-emerald-700" : "text-red-600"}`}>
            {deltaAvg.isUp ? "↑" : "↓"} {deltaAvg.pct}% vs mes anterior
          </p>
        )}
      </div>
      <div class={cardClass}>
        <p class="text-xs text-gray-500 mb-1">Material más usado</p>
        {topMaterial ? (
          <>
            <p class="text-3xl font-display">
              {MATERIAL_LABELS[topMaterial.name as keyof typeof MATERIAL_LABELS] ?? topMaterial.name}
            </p>
            <p class="text-xs mt-1 text-gray-500">{topMaterial.count} pedido{topMaterial.count === 1 ? "" : "s"}</p>
          </>
        ) : (
          <p class="text-3xl font-display text-gray-400">—</p>
        )}
      </div>
    </div>
  </section>

  {/* ─── Sección 3: Próximas entregas ─── */}
  <section class="mb-6">
    <div class="flex items-center justify-between mb-2">
      <h2 class="text-xs uppercase tracking-wider text-brand/60 font-medium">Próximas entregas</h2>
      {upcomingCount > 0 && (
        <a
          href={`/admin/pedidos?delivery_from=${todayStr}&delivery_to=${in7DaysStr}`}
          class="text-xs text-accent hover:underline"
        >
          Ver todas →
        </a>
      )}
    </div>
    {upcomingItems.length === 0 ? (
      <div class={cardClass + " text-center text-sm text-gray-500"}>
        Sin entregas en los próximos 7 días.
      </div>
    ) : (
      <div class="bg-white border-2 border-brand rounded-lg overflow-hidden shadow-[4px_4px_0_var(--color-brand)]">
        <table class="w-full text-sm">
          <thead class="bg-surface border-b-2 border-brand">
            <tr>
              <th class="text-left px-3 py-2 font-medium w-20">Entrega</th>
              <th class="text-left px-3 py-2 font-medium">Proyecto</th>
              <th class="text-left px-3 py-2 font-medium hidden sm:table-cell">Cliente</th>
              <th class="text-left px-3 py-2 font-medium hidden md:table-cell">Material</th>
              <th class="text-left px-3 py-2 font-medium">Estado</th>
              <th class="text-right px-3 py-2 font-medium"></th>
            </tr>
          </thead>
          <tbody>
            {upcomingItems.slice(0, 10).map((o) => (
              <tr class="border-b border-brand/10 hover:bg-surface/50 transition-colors">
                <td class={`px-3 py-2 font-mono text-xs whitespace-nowrap ${isOverdue(o) ? "text-red-600 font-medium" : "text-gray-700"}`}>
                  {isOverdue(o) && "⚠ "}{fmtDeliveryDate(o.delivery_date)}
                </td>
                <td class="px-3 py-2">
                  <div class="font-medium truncate max-w-[16ch] sm:max-w-none">{o.project_name}</div>
                  <div class="text-xs text-gray-500 sm:hidden">{o.customer_name}</div>
                </td>
                <td class="px-3 py-2 hidden sm:table-cell text-gray-700">{o.customer_name}</td>
                <td class="px-3 py-2 hidden md:table-cell">
                  <MaterialColorChip material={o.material} color={o.color} />
                </td>
                <td class="px-3 py-2">
                  <OrderStatusBadge status={o.status} />
                </td>
                <td class="px-3 py-2 text-right">
                  <a
                    href={`/admin/pedidos/${o.id}`}
                    class="text-xs text-accent hover:underline whitespace-nowrap"
                  >
                    Ver →
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </section>

  {/* ─── Sección 4: Por cobrar ─── */}
  <section>
    <div class="flex items-center justify-between mb-2">
      <h2 class="text-xs uppercase tracking-wider text-brand/60 font-medium">Por cobrar</h2>
      {toCollectCount > 0 && (
        <a
          href="/admin/pedidos?status=delivered&paid=no&show_finalized=1"
          class="text-xs text-accent hover:underline"
        >
          Ver todos →
        </a>
      )}
    </div>
    {toCollectItems.length === 0 ? (
      <div class={cardClass + " text-center text-sm text-gray-500"}>
        Todo cobrado. 🎉
      </div>
    ) : (
      <div class="bg-white border-2 border-brand rounded-lg overflow-hidden shadow-[4px_4px_0_var(--color-brand)]">
        <table class="w-full text-sm">
          <thead class="bg-surface border-b-2 border-brand">
            <tr>
              <th class="text-left px-3 py-2 font-medium">Proyecto</th>
              <th class="text-left px-3 py-2 font-medium hidden sm:table-cell">Cliente</th>
              <th class="text-right px-3 py-2 font-medium">Saldo</th>
              <th class="text-right px-3 py-2 font-medium"></th>
            </tr>
          </thead>
          <tbody>
            {toCollectItems.slice(0, 10).map((o) => {
              const total = (Number(o.unit_price) || 0) * (Number(o.units_ordered) || 0);
              const balance = Math.max(0, total - (Number(o.paid_amount) || 0));
              const partialPaid = (Number(o.paid_amount) || 0) > 0;
              return (
                <tr class="border-b border-brand/10 hover:bg-surface/50 transition-colors">
                  <td class="px-3 py-2">
                    <div class="font-medium truncate max-w-[20ch] sm:max-w-none">{o.project_name}</div>
                    <div class="text-xs text-gray-500 sm:hidden">{o.customer_name}</div>
                  </td>
                  <td class="px-3 py-2 hidden sm:table-cell text-gray-700">{o.customer_name}</td>
                  <td class="px-3 py-2 text-right whitespace-nowrap">
                    <div class="font-mono font-medium text-amber-700">{fmtArs(balance)}</div>
                    {partialPaid && (
                      <div class="text-xs text-gray-500 font-mono mt-0.5">
                        {fmtArs(Number(o.paid_amount))} de {fmtArs(total)}
                      </div>
                    )}
                  </td>
                  <td class="px-3 py-2 text-right">
                    <a
                      href={`/admin/pedidos/${o.id}`}
                      class="text-xs text-accent hover:underline whitespace-nowrap"
                    >
                      Ver →
                    </a>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    )}
  </section>
</AdminLayout>
