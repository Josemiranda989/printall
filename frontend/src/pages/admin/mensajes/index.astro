---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import {
  APPLIES_TO_LABELS,
  fetchAllTemplates,
} from "../../../lib/admin-templates";

const pb = Astro.locals.adminPB!;
const templates = await fetchAllTemplates(pb);

function preview(body: string): string {
  if (body.length <= 80) return body;
  return body.slice(0, 80) + "…";
}
---

<AdminLayout title="Mensajes">
  <div class="flex items-center justify-between gap-3 mb-5 flex-wrap">
    <div class="min-w-0">
      <h1 class="font-display text-2xl sm:text-3xl">Mensajes de WhatsApp</h1>
      <p class="text-xs sm:text-sm text-gray-600 mt-1">
        Plantillas reutilizables. Soportan placeholders como <code class="font-mono text-xs">&#123;&#123;customer_name&#125;&#125;</code>.
      </p>
    </div>
    <div class="shrink-0">
      <a
        href="/admin/mensajes/nuevo"
        class="bg-accent text-white font-medium px-3 sm:px-4 py-2 rounded-md hover:bg-accent-hover transition-colors text-sm whitespace-nowrap"
      >
        <span class="sm:hidden">+ Nuevo</span>
        <span class="hidden sm:inline">+ Nuevo mensaje</span>
      </a>
    </div>
  </div>

  {templates.length === 0 ? (
    <div class="border-2 border-dashed border-brand/30 rounded-lg p-12 text-center bg-white">
      <p class="text-gray-600 mb-4">Todavía no hay mensajes.</p>
      <a href="/admin/mensajes/nuevo" class="text-accent hover:underline font-medium">
        Crear el primero →
      </a>
    </div>
  ) : (
    <div class="bg-white border-2 border-brand rounded-lg overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-surface border-b-2 border-brand">
          <tr>
            <th class="text-left px-2 sm:px-4 py-3 font-medium">Nombre</th>
            <th class="text-left px-2 sm:px-4 py-3 font-medium hidden sm:table-cell">Aplica a</th>
            <th class="text-left px-2 sm:px-4 py-3 font-medium hidden md:table-cell">Vista previa</th>
            <th class="text-right px-2 sm:px-4 py-3 font-medium">Acción</th>
          </tr>
        </thead>
        <tbody>
          {templates.map((t) => (
            <tr
              class="border-b border-brand/10 hover:bg-surface/50 transition-colors cursor-pointer"
              data-row-href={`/admin/mensajes/${t.id}`}
            >
              <td class="px-2 sm:px-4 py-3">
                <div class="font-medium break-words">{t.name}</div>
                <div class="sm:hidden text-xs text-gray-500 mt-0.5">
                  {APPLIES_TO_LABELS[t.applies_to]}
                </div>
              </td>
              <td class="px-2 sm:px-4 py-3 hidden sm:table-cell">
                <span class="text-xs uppercase tracking-wide font-semibold px-2 py-0.5 rounded bg-brand/10 text-brand">
                  {APPLIES_TO_LABELS[t.applies_to]}
                </span>
              </td>
              <td class="px-2 sm:px-4 py-3 text-gray-600 hidden md:table-cell">
                <span class="font-mono text-xs break-words">{preview(t.body)}</span>
              </td>
              <td class="px-2 sm:px-4 py-3 text-right">
                <a
                  href={`/admin/mensajes/${t.id}`}
                  class="inline-block px-2 sm:px-3 py-1 border-2 border-brand rounded hover:bg-brand hover:text-white transition-colors text-xs font-medium whitespace-nowrap"
                  onclick="event.stopPropagation()"
                >
                  Editar
                </a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}

  <script>
    document.querySelectorAll<HTMLElement>("[data-row-href]").forEach((row) => {
      row.addEventListener("click", (ev) => {
        const target = ev.target as HTMLElement;
        if (target.closest("input, button, a, label, select, option")) return;
        const href = row.dataset.rowHref;
        if (href) window.location.href = href;
      });
    });
  </script>
</AdminLayout>
