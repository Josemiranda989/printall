---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import {
  QUOTE_STATUS_COLORS,
  QUOTE_STATUS_LABELS,
  fetchAllQuotes,
  quoteTotal,
} from "../../../lib/admin-quotes";

const pb = Astro.locals.adminPB!;
const quotes = await fetchAllQuotes(pb);

function fmtMoney(n: number): string {
  return "$" + Math.round(n).toLocaleString("es-AR");
}

function fmtDate(iso: string): string {
  if (!iso) return "—";
  return iso.slice(0, 10);
}
---

<AdminLayout title="Cotizaciones">
  <div class="flex items-center justify-between gap-3 mb-5 flex-wrap">
    <div class="min-w-0">
      <h1 class="font-display text-2xl sm:text-3xl">Cotizaciones</h1>
      <p class="text-xs sm:text-sm text-gray-600 mt-1">
        Pre-pedidos: cuando el cliente pide precio sin confirmar todavía.
      </p>
    </div>
    <a
      href="/admin/cotizaciones/nueva"
      class="bg-accent text-white font-medium px-3 sm:px-4 py-2 rounded-md hover:bg-accent-hover transition-colors text-sm whitespace-nowrap"
    >
      + Nueva cotización
    </a>
  </div>

  {quotes.length === 0 ? (
    <div class="border-2 border-dashed border-brand/30 rounded-lg p-12 text-center bg-white">
      <p class="text-gray-600 mb-2">Sin cotizaciones aún.</p>
      <a href="/admin/cotizaciones/nueva" class="text-accent hover:underline font-medium">
        Crear la primera →
      </a>
    </div>
  ) : (
    <div class="bg-white border-2 border-brand rounded-lg overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-surface border-b-2 border-brand">
          <tr>
            <th class="text-left px-2 sm:px-4 py-3 font-medium">Título</th>
            <th class="text-left px-3 py-3 font-medium hidden md:table-cell">Cliente</th>
            <th class="text-right px-3 py-3 font-medium">Total</th>
            <th class="text-left px-3 py-3 font-medium">Estado</th>
            <th class="text-right px-3 py-3 font-medium hidden md:table-cell">Creada</th>
            <th class="text-right px-2 sm:px-4 py-3 font-medium">Acción</th>
          </tr>
        </thead>
        <tbody>
          {quotes.map((q) => (
            <tr
              class="border-b border-brand/10 hover:bg-surface/50 transition-colors cursor-pointer"
              data-row-href={`/admin/cotizaciones/${q.id}`}
            >
              <td class="px-2 sm:px-4 py-3">
                <div class="font-medium break-words">{q.title}</div>
                <div class="md:hidden text-xs text-gray-500 mt-0.5">{q.customer_name}</div>
              </td>
              <td class="px-3 py-3 hidden md:table-cell break-words">{q.customer_name}</td>
              <td class="px-3 py-3 text-right font-mono font-medium whitespace-nowrap">
                {fmtMoney(quoteTotal(q))}
              </td>
              <td class="px-3 py-3">
                <span class={`inline-block px-2 py-0.5 rounded text-xs font-medium ${QUOTE_STATUS_COLORS[q.status]}`}>
                  {QUOTE_STATUS_LABELS[q.status]}
                </span>
              </td>
              <td class="px-3 py-3 text-right font-mono text-gray-600 hidden md:table-cell whitespace-nowrap">
                {fmtDate(q.created)}
              </td>
              <td class="px-2 sm:px-4 py-3 text-right">
                <a
                  href={`/admin/cotizaciones/${q.id}`}
                  class="inline-block px-2 sm:px-3 py-1 border-2 border-brand rounded hover:bg-brand hover:text-white transition-colors text-xs font-medium whitespace-nowrap"
                  onclick="event.stopPropagation()"
                >
                  Ver
                </a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}

  <script>
    document.querySelectorAll<HTMLElement>("[data-row-href]").forEach((row) => {
      row.addEventListener("click", (ev) => {
        const target = ev.target as HTMLElement;
        if (target.closest("input, button, a, label, select, option")) return;
        const href = row.dataset.rowHref;
        if (href) window.location.href = href;
      });
    });
  </script>
</AdminLayout>
