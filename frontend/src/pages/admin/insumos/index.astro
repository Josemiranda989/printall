---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import {
  SUPPLY_SALE_STATUS_LABELS,
  SUPPLY_SALE_STATUS_COLORS,
  SUPPLY_SALE_STATUS_VALUES,
  supplySaleTotal,
  type SupplySaleWithItem,
} from "../../../lib/types";

const pb = Astro.locals.adminPB!;

// Toggle para mostrar/ocultar pagados (default: ocultos)
const showPaid = Astro.url.searchParams.get("mostrar_pagados") === "1";

const pbFilter = showPaid ? "" : "is_paid = false";

const records = (await pb.collection("supply_sales").getFullList({
  filter: pbFilter || undefined,
  sort: "-sale_date,-created",
  expand: "item",
  batch: 200,
})) as unknown as SupplySaleWithItem[];

// Contar cuántos pagados están ocultos (para el badge del toggle)
let hiddenPaidCount = 0;
if (!showPaid) {
  const countRes = await pb.collection("supply_sales").getList(1, 1, {
    filter: "is_paid = true",
    fields: "id",
  });
  hiddenPaidCount = countRes.totalItems;
}

function fmtMoney(n: number): string {
  return "$" + Math.round(n).toLocaleString("es-AR");
}

function fmtDate(d: string): string {
  if (!d) return "—";
  return d.slice(0, 10);
}
---

<AdminLayout title="Insumos">
  <div class="flex items-center justify-between gap-3 mb-5 flex-wrap">
    <div class="min-w-0">
      <h1 class="font-display text-2xl sm:text-3xl">Ventas de insumos</h1>
      <p class="text-xs sm:text-sm text-gray-600 mt-1">
        Filamentos, adhesivos, accesorios y demás insumos vendidos.
      </p>
    </div>
    <div class="flex items-center gap-2 shrink-0">
      <a
        href="/admin/insumos/reporte"
        class="border-2 border-brand text-brand font-medium px-3 sm:px-4 py-2 rounded-md hover:bg-brand hover:text-white transition-colors text-sm whitespace-nowrap"
      >
        Reporte
      </a>
      <a
        href="/admin/insumos/nuevo"
        class="bg-accent text-white font-medium px-3 sm:px-4 py-2 rounded-md hover:bg-accent-hover transition-colors text-sm whitespace-nowrap"
      >
        <span class="sm:hidden">+ Nueva</span>
        <span class="hidden sm:inline">+ Nueva venta</span>
      </a>
    </div>
  </div>

  <!-- Toggle mostrar pagados -->
  <div class="flex items-center gap-4 mb-4 flex-wrap">
    <label class="inline-flex items-center gap-2 cursor-pointer text-sm">
      <input
        type="checkbox"
        class="w-4 h-4 accent-accent"
        checked={showPaid}
        onchange={`window.location.href = this.checked ? '?mostrar_pagados=1' : '?'`}
      />
      <span>Mostrar pagados</span>
      {hiddenPaidCount > 0 && !showPaid && (
        <span class="text-xs bg-accent/10 text-accent px-2 py-0.5 rounded-full font-mono">
          {hiddenPaidCount} ocultos
        </span>
      )}
    </label>
  </div>

  {records.length === 0 ? (
    <div class="border-2 border-dashed border-brand/30 rounded-lg p-12 text-center bg-white">
      <p class="text-gray-600 mb-4">
        Todavía no hay ventas de insumos registradas.
      </p>
      <a
        href="/admin/insumos/nuevo"
        class="text-accent hover:underline font-medium"
      >
        Registrar la primera →
      </a>
    </div>
  ) : (
    <div class="bg-white border-2 border-brand rounded-lg overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-surface border-b-2 border-brand">
          <tr>
            <th class="text-left px-2 sm:px-4 py-3 font-medium">Cliente</th>
            <th class="text-left px-4 py-3 font-medium hidden md:table-cell">Insumo</th>
            <th class="text-right px-2 sm:px-4 py-3 font-medium hidden sm:table-cell">Cant.</th>
            <th class="text-left px-2 sm:px-4 py-3 font-medium hidden md:table-cell">Color</th>
            <th class="text-right px-2 sm:px-4 py-3 font-medium">Total</th>
            <th class="text-left px-2 sm:px-4 py-3 font-medium">Estado</th>
            <th class="text-center px-2 sm:px-4 py-3 font-medium hidden sm:table-cell">Pago</th>
            <th class="text-right px-2 sm:px-4 py-3 font-medium hidden md:table-cell">Fecha</th>
            <th class="text-right px-2 sm:px-4 py-3 font-medium">Acción</th>
          </tr>
        </thead>
        <tbody>
          {records.map((s) => (
            <tr
              class="border-b border-brand/10 hover:bg-surface/50 transition-colors cursor-pointer"
              data-row-href={`/admin/insumos/${s.id}`}
            >
              <td class="px-2 sm:px-4 py-3">
                <div class="font-medium break-words">{s.customer_name}</div>
                <div class="md:hidden text-xs text-gray-500 mt-0.5">
                  {s.expand?.item?.name ?? "(insumo eliminado)"} · ×{s.quantity}
                </div>
              </td>
              <td class="px-4 py-3 text-gray-700 hidden md:table-cell">
                {s.expand?.item?.name ?? "(insumo eliminado)"}
              </td>
              <td class="px-2 sm:px-4 py-3 text-right font-mono hidden sm:table-cell">
                {s.quantity}
              </td>
              <td class="px-2 sm:px-4 py-3 text-gray-700 hidden md:table-cell">
                {s.color || "—"}
              </td>
              <td class="px-2 sm:px-4 py-3 text-right font-mono font-medium whitespace-nowrap">
                {fmtMoney(supplySaleTotal(s))}
              </td>
              <td class="px-2 sm:px-4 py-3">
                <select
                  class={`status-inline-select text-[11px] sm:text-xs px-1.5 sm:px-2 py-0.5 rounded border font-medium cursor-pointer max-w-[8rem] sm:max-w-none ${SUPPLY_SALE_STATUS_COLORS[s.status]}`}
                  data-sale-id={s.id}
                  data-current={s.status}
                  aria-label="Cambiar estado"
                >
                  {SUPPLY_SALE_STATUS_VALUES.map((v) => (
                    <option value={v} selected={v === s.status}>
                      {SUPPLY_SALE_STATUS_LABELS[v]}
                    </option>
                  ))}
                </select>
              </td>
              <td class="px-2 sm:px-4 py-3 text-center align-middle hidden sm:table-cell">
                <input
                  type="checkbox"
                  class="w-5 h-5 sm:w-4 sm:h-4 accent-emerald-600 cursor-pointer"
                  checked={s.is_paid}
                  data-paid-toggle
                  data-sale-id={s.id}
                  aria-label="Marcar como pagado"
                />
              </td>
              <td class="px-2 sm:px-4 py-3 text-right font-mono text-gray-600 hidden md:table-cell whitespace-nowrap">
                {fmtDate(s.sale_date)}
              </td>
              <td class="px-2 sm:px-4 py-3 text-right">
                <a
                  href={`/admin/insumos/${s.id}`}
                  class="inline-block px-2 sm:px-3 py-1 border-2 border-brand rounded hover:bg-brand hover:text-white transition-colors text-xs font-medium whitespace-nowrap"
                  onclick="event.stopPropagation()"
                >
                  Editar
                </a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}
<script
  is:inline
  type="application/json"
  id="supply-sale-status-colors"
  set:html={JSON.stringify(SUPPLY_SALE_STATUS_COLORS)}
/>

<script>
  const colorsRaw =
    document.getElementById("supply-sale-status-colors")?.textContent ?? "{}";
  const STATUS_COLORS = JSON.parse(colorsRaw) as Record<string, string>;

  // ─── Filas clickables (excepto sobre interactivos) ───
  document.querySelectorAll<HTMLElement>("[data-row-href]").forEach((row) => {
    row.addEventListener("click", (ev) => {
      const target = ev.target as HTMLElement;
      if (target.closest("input, button, a, label, select, option")) return;
      const href = row.dataset.rowHref;
      if (href) window.location.href = href;
    });
  });

  // ─── Toggle pagado optimista ───
  document.querySelectorAll<HTMLInputElement>("[data-paid-toggle]").forEach((cb) => {
    cb.addEventListener("change", async (ev) => {
      ev.stopPropagation();
      const saleId = cb.dataset.saleId!;
      const newValue = cb.checked;
      cb.disabled = true;
      try {
        const res = await fetch(`/admin/api/supply_sales/${saleId}/paid`, {
          method: "PATCH",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ is_paid: newValue }),
        });
        const data = (await res.json()) as { ok: boolean; error?: string };
        if (!res.ok || !data.ok) {
          cb.checked = !newValue;
          (window as any).__showToast && (window as any).__showToast({ type: 'error', message: data.error || "No se pudo cambiar el estado de pago." });
        }
      } catch {
        cb.checked = !newValue;
        (window as any).__showToast && (window as any).__showToast({ type: 'error', message: "Error de red al cambiar el estado de pago." });
      } finally {
        cb.disabled = false;
      }
    });
    cb.addEventListener("click", (ev) => ev.stopPropagation());
  });

  // ─── Inline select de estado ───
  document
    .querySelectorAll<HTMLSelectElement>(".status-inline-select")
    .forEach((sel) => {
      sel.addEventListener("click", (ev) => ev.stopPropagation());
      sel.addEventListener("change", async (ev) => {
        ev.stopPropagation();
        const saleId = sel.dataset.saleId!;
        const previous = sel.dataset.current!;
        const newValue = sel.value;
        if (newValue === previous) return;

        if (
          newValue === "cancelado" &&
          !confirm("¿Marcar esta venta como cancelada?")
        ) {
          sel.value = previous;
          return;
        }

        function applyClass(value: string) {
          for (const v of Object.keys(STATUS_COLORS)) {
            STATUS_COLORS[v].split(" ").forEach((c) => c && sel.classList.remove(c));
          }
          (STATUS_COLORS[value] ?? "")
            .split(" ")
            .forEach((c) => c && sel.classList.add(c));
        }
        applyClass(newValue);
        sel.dataset.current = newValue;
        sel.disabled = true;

        try {
          const res = await fetch(`/admin/api/supply_sales/${saleId}/status`, {
            method: "PATCH",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ status: newValue }),
          });
          const data = (await res.json()) as { ok: boolean; error?: string };
          if (!res.ok || !data.ok) {
            sel.value = previous;
            applyClass(previous);
            sel.dataset.current = previous;
            (window as any).__showToast && (window as any).__showToast({ type: 'error', message: data.error || "No se pudo actualizar." });
          }
        } catch {
          sel.value = previous;
          applyClass(previous);
          sel.dataset.current = previous;
          (window as any).__showToast && (window as any).__showToast({ type: 'error', message: "Error de red." });
        } finally {
          sel.disabled = false;
        }
      });
    });
</script>
