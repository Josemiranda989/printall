---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import SupplySaleForm from "../../../components/admin/SupplySaleForm.astro";
import {
  extractSupplySaleFromForm,
  type SupplySaleFormData,
} from "../../../lib/admin-supply-sales";
import WhatsAppTemplateMenu from "../../../components/admin/WhatsAppTemplateMenu.astro";
import { fetchClientsForAutocomplete } from "../../../lib/admin-clients";
import { fetchTemplatesFor, getSaleContext } from "../../../lib/admin-templates";
import { mapPBErrorToFieldErrors } from "../../../lib/admin-errors";
import { supplySaleTotal, type MaterialPrice, type SupplySale } from "../../../lib/types";

const pb = Astro.locals.adminPB!;
const { id } = Astro.params;
if (!id) return Astro.redirect("/admin/insumos");

let record: SupplySale & { color?: string };
try {
  record = (await pb
    .collection("supply_sales")
    .getOne(id)) as unknown as SupplySale;
} catch {
  return new Response("Venta no encontrada", { status: 404 });
}

const [materials, clients, templates] = await Promise.all([
  pb.collection("materials").getFullList({
    filter: "active = true",
    sort: "name",
    batch: 200,
  }) as unknown as Promise<MaterialPrice[]>,
  fetchClientsForAutocomplete(pb),
  fetchTemplatesFor(pb, "sale"),
]);

const itemMaterial = materials.find((m) => m.id === record.item) ?? null;
const materialName = itemMaterial?.name ?? record.item;
const templateContext = getSaleContext(record, { item_name: materialName });

let values: Partial<SupplySaleFormData> = {
  customer_name: record.customer_name,
  customer_whatsapp: record.customer_whatsapp,
  item: record.item,
  quantity: record.quantity,
  unit_price: record.unit_price,
  status: record.status,
  is_paid: record.is_paid,
  color: record.color ?? "",
  sale_date: record.sale_date ? record.sale_date.slice(0, 10) : "",
  delivery_date: record.delivery_date ? record.delivery_date.slice(0, 10) : "",
  notes: record.notes,
};
let errors: Record<string, string> = {};

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = String(form.get("action") ?? "save");

  if (action === "delete") {
    try {
      await pb.collection("supply_sales").delete(id);
      const toastName = encodeURIComponent(record.customer_name || "sin nombre");
      return Astro.redirect(`/admin/insumos?toast=deleted&name=${toastName}&collection=supply_sales`);
    } catch (err: unknown) {
      errors = mapPBErrorToFieldErrors(err, "generic");
      if (!errors._global) errors._global = "No se pudo eliminar la venta.";
    }
  } else {
    const result = extractSupplySaleFromForm(form);
    values = result.data;
    errors = result.errors;

    if (Object.keys(errors).length === 0) {
      try {
        await pb.collection("supply_sales").update(id, {
          customer_name: result.data.customer_name,
          customer_whatsapp: result.data.customer_whatsapp,
          item: result.data.item,
          quantity: result.data.quantity,
          unit_price: result.data.unit_price,
          status: result.data.status,
          is_paid: result.data.is_paid,
          color: result.data.color,
          sale_date: result.data.sale_date,
          delivery_date: result.data.delivery_date,
          notes: result.data.notes,
        });
        const toastName = encodeURIComponent(record.customer_name || "sin nombre");
        return Astro.redirect(`/admin/insumos?toast=saved&name=${toastName}&collection=supply_sales`);
      } catch (err: unknown) {
        errors = { ...errors, ...mapPBErrorToFieldErrors(err, "generic") };
      }
    }
  }
}

const total = supplySaleTotal(record);

// ─── Bloque "Datos para cobrar" ─────────────────────────────────────
// Solo se muestra si hay alias BNA configurado y la venta no está paga.
// El botón "Copiar mensaje" copia texto plano listo para WhatsApp.
const bnaAlias = (process.env.BNA_ALIAS as string | undefined) ?? "";
const bnaHolder = (process.env.BNA_HOLDER_NAME as string | undefined) ?? "";
const balanceDue = record.is_paid ? 0 : total;
const showCobrarBlock = bnaAlias.trim().length > 0 && balanceDue > 0;

let cobrarMessage = "";
if (showCobrarBlock) {
  const colorHint = record.color ? ` (${record.color})` : "";
  const balanceFmt = "$" + Math.round(balanceDue).toLocaleString("es-AR");
  cobrarMessage =
    `Hola! El saldo de ${materialName}${colorHint} es ${balanceFmt}. ` +
    `¡Gracias! Alias: ${bnaAlias}`;
}

const recordForUndoJson = JSON.stringify({
  customer_name: record.customer_name,
  customer_whatsapp: record.customer_whatsapp,
  item: record.item,
  quantity: record.quantity,
  unit_price: record.unit_price,
  status: record.status,
  is_paid: record.is_paid,
  color: record.color || "",
  sale_date: record.sale_date,
  delivery_date: record.delivery_date,
  notes: record.notes,
});
---

<AdminLayout title={`Venta: ${record.customer_name}`}>
  <div class="mb-6">
    <h1 class="font-display text-2xl sm:text-3xl break-words">
      Venta a {record.customer_name}
    </h1>
    <p class="text-xs sm:text-sm text-gray-600 mt-1 font-mono break-all">
      id: {id}
    </p>
  </div>

  {/* ─── Datos para cobrar (solo si no está pago y BNA configurado) ─── */}
  {showCobrarBlock && (
    <details class="bg-amber-50 border-2 border-amber-500 rounded-lg mb-5 shadow-[4px_4px_0_var(--color-brand)] overflow-hidden">
      <summary class="cursor-pointer px-4 py-3 font-medium text-sm sm:text-base hover:bg-amber-100/50 select-none">
        💰 Datos para cobrar
      </summary>
      <div class="border-t-2 border-amber-300 p-4 sm:p-5">
      <div class="space-y-1.5 text-sm mb-3">
        <p>
          <span class="text-gray-600">Alias:</span>
          <span class="font-mono font-medium ml-1 select-all">{bnaAlias}</span>
        </p>
        {bnaHolder && (
          <p>
            <span class="text-gray-600">Titular:</span>
            <span class="font-medium ml-1">{bnaHolder}</span>
          </p>
        )}
        <p>
          <span class="text-gray-600">Banco:</span>
          <span class="font-medium ml-1">Banco Nación</span>
        </p>
        <p>
          <span class="text-gray-600">Saldo a cobrar:</span>
          <span class="font-mono font-bold text-amber-800 ml-1">
            ${Math.round(balanceDue).toLocaleString("es-AR")}
          </span>
        </p>
      </div>

      <pre class="bg-white border-2 border-amber-300 rounded-md p-3 text-xs sm:text-sm font-mono whitespace-pre-wrap break-words mb-3 select-all">{cobrarMessage}</pre>

      <button
        type="button"
        data-copy-message
        data-message={cobrarMessage}
        class="inline-flex items-center gap-2 px-4 py-2 bg-brand text-white rounded-md text-sm font-medium hover:bg-accent transition-colors"
      >
        📋 <span data-copy-message-label>Copiar mensaje</span>
      </button>
      </div>
    </details>
  )}

  {/* ─── Mensajes de WhatsApp ─── */}
  <div class="mb-5">
    <WhatsAppTemplateMenu
      templates={templates}
      context={templateContext}
      customerWhatsapp={record.customer_whatsapp ?? ""}
    />
  </div>

  <SupplySaleForm
    values={values}
    errors={errors}
    mode="edit"
    saleId={id}
    materials={materials}
    clients={clients}
  />
</AdminLayout>

{/* ─── Save record to sessionStorage before delete (for undo) ─── */}
<script define:vars={{ recordJson: recordForUndoJson }}>
  (function() {
    var recordData = JSON.parse(recordJson);

    document.addEventListener("click", (e) => {
      const target = /** @type {HTMLElement|null} */ (e.target);
      if (!target) return;
      const btn = target.closest("button[name='action'][value='delete']");
      if (!btn) return;
      try {
        sessionStorage.setItem("lastDeleted", JSON.stringify({
          collection: "supply_sales",
          data: recordData,
          name: recordData.customer_name || "",
        }));
      } catch {}
    }, { capture: true });
  })();
</script>

<script>
  function initCopySupplySale() {
    const btn = document.getElementById("copy-btn") as HTMLButtonElement | null;
    const label = document.getElementById("copy-btn-label");
    const pre = document.getElementById("copy-data");
    if (!btn || !label || !pre) return;
    const original = label.textContent ?? "Copiar";
    btn.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(pre.textContent ?? "");
        label.textContent = "✓ Copiado";
        btn.disabled = true;
        setTimeout(() => {
          label.textContent = original;
          btn.disabled = false;
        }, 2000);
      } catch {
        label.textContent = "Falló — copiá a mano";
        setTimeout(() => {
          label.textContent = original;
        }, 2000);
      }
    });
  }

  initCopySupplySale();
  document.addEventListener("astro:page-load", initCopySupplySale);
</script>
