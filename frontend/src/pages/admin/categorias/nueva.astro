---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import CategoryForm from "../../../components/admin/CategoryForm.astro";
import { extractCategoryFromForm } from "../../../lib/admin-categories";
import type { CategoryFormData } from "../../../lib/admin-categories";

const pb = Astro.locals.adminPB!;

let values: Partial<CategoryFormData> = {
  active: true,
  order: 0,
};
let errors: Record<string, string> = {};

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const result = extractCategoryFromForm(form);
  values = result.data;
  errors = result.errors;

  if (Object.keys(errors).length === 0) {
    try {
      const created = await pb.collection("categories").create({
        name: result.data.name,
        slug: result.data.slug,
        icon: result.data.icon,
        description: result.data.description,
        order: result.data.order,
        active: result.data.active,
      });
      return Astro.redirect("/admin/categorias?ok=created");
    } catch (err: unknown) {
      const e = err as {
        message?: string;
        response?: { data?: Record<string, { message?: string }> };
      };
      const fieldErrors = e.response?.data ?? {};

      // Slug duplicado: PB arroja error en el campo "slug"
      if (fieldErrors.slug?.message) {
        errors.slug = "Ese slug ya existe. Elegí uno diferente.";
      }

      for (const [field, info] of Object.entries(fieldErrors)) {
        if (field !== "slug" && info?.message) {
          errors[field] = info.message;
        }
      }

      if (Object.keys(errors).length === 0) {
        errors._global = e.message ?? "No se pudo crear la categoría.";
      }
    }
  }
}
---

<AdminLayout title="Nueva categoría">
  <div class="mb-6">
    <h1 class="font-display text-3xl">Nueva categoría</h1>
    <p class="text-sm text-gray-600 mt-1">
      Creá una categoría para organizar los productos del catálogo.
    </p>
  </div>

  <CategoryForm values={values} errors={errors} mode="create" />
</AdminLayout>
