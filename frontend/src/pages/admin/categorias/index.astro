---
import AdminLayout from "../../../layouts/AdminLayout.astro";

const pb = Astro.locals.adminPB!;

// Traer todas las categorías ordenadas por order asc, luego por name
const categoriesRaw = await pb.collection("categories").getFullList({
  sort: "+order,+name",
});

// Contar productos por categoría: una sola query de todos los productos y contamos en memoria.
// Más eficiente que hacer N queries (una por categoría) — especialmente con 8 categorías.
const allProductsRaw = await pb.collection("products").getFullList({
  fields: "category",
});

const productCountByCategory: Record<string, number> = {};
for (const p of allProductsRaw) {
  const catId = p.category as string;
  if (catId) {
    productCountByCategory[catId] = (productCountByCategory[catId] ?? 0) + 1;
  }
}

type CategoryRecord = {
  id: string;
  name: string;
  slug: string;
  icon: string;
  description: string;
  order: number;
  active: boolean;
};

const categories = categoriesRaw as unknown as CategoryRecord[];

const url = new URL(Astro.request.url);
const okParam = url.searchParams.get("ok");
let flash: string | null = null;
if (okParam === "created") flash = "Categoría creada correctamente.";
if (okParam === "saved") flash = "Cambios guardados.";
if (okParam === "deleted") flash = "Categoría eliminada.";
---

<AdminLayout title="Categorías">
  <div class="flex items-center justify-between gap-3 mb-6">
    <div class="min-w-0">
      <h1 class="font-display text-2xl sm:text-3xl">Categorías</h1>
      <p class="text-xs sm:text-sm text-gray-600 mt-1">
        {categories.length} {categories.length === 1 ? "categoría" : "categorías"} en total
      </p>
    </div>
    <a
      href="/admin/categorias/nueva"
      class="bg-accent text-white font-medium px-3 sm:px-4 py-2 rounded-md hover:bg-accent-hover transition-colors text-sm shrink-0 whitespace-nowrap"
    >
      <span class="sm:hidden">+ Nueva</span>
      <span class="hidden sm:inline">+ Nueva categoría</span>
    </a>
  </div>

  {flash && (
    <div class="border-2 border-emerald-600 bg-emerald-50 text-emerald-800 px-3 py-2 rounded-md text-sm mb-4">
      {flash}
    </div>
  )}

  <!-- Error de reorder drag-and-drop -->
  <div
    id="categories-error"
    class="hidden border-2 border-red-500 bg-red-50 text-red-800 px-3 py-2 rounded-md text-sm mb-4"
    role="alert"
  ></div>

  {categories.length === 0 ? (
    <div class="border-2 border-dashed border-brand/30 rounded-lg p-12 text-center bg-white">
      <p class="text-gray-600 mb-4">Todavía no hay categorías cargadas.</p>
      <a href="/admin/categorias/nueva" class="text-accent hover:underline font-medium">
        Crear la primera →
      </a>
    </div>
  ) : (
    <div class="bg-white border-2 border-brand rounded-lg overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-surface border-b-2 border-brand">
          <tr>
            <th class="text-left px-2 sm:px-3 py-3 font-medium w-10 sm:w-8"></th>
            <th class="text-left px-4 py-3 font-medium hidden sm:table-cell w-12">Icono</th>
            <th class="text-left px-2 sm:px-4 py-3 font-medium">Nombre</th>
            <th class="text-left px-4 py-3 font-medium hidden md:table-cell">Slug</th>
            <th class="text-left px-4 py-3 font-medium hidden sm:table-cell w-20">Orden</th>
            <th class="text-left px-2 sm:px-4 py-3 font-medium w-20 sm:w-24">Estado</th>
            <th class="text-left px-4 py-3 font-medium hidden sm:table-cell w-24">Productos</th>
            <th class="text-right px-2 sm:px-4 py-3 font-medium">Acciones</th>
          </tr>
        </thead>
        <tbody id="categories-list">
          {categories.map((cat) => {
            const count = productCountByCategory[cat.id] ?? 0;
            return (
              <tr
                class={`border-b border-brand/10 hover:bg-surface/50 transition-colors ${!cat.active ? "opacity-60" : ""}`}
                data-category-id={cat.id}
              >
                <td class="px-1 sm:px-3 py-3">
                  <button
                    type="button"
                    class="category-drag-handle cursor-grab text-gray-400 hover:text-gray-600 select-none text-xl sm:text-lg leading-none w-10 h-10 sm:w-auto sm:h-auto flex items-center justify-center touch-manipulation"
                    title="Arrastrar para reordenar"
                    aria-label="Reordenar categoría"
                  >
                    ≡
                  </button>
                </td>
                <td class="px-4 py-3 text-xl text-center hidden sm:table-cell">
                  {cat.icon || <span class="text-gray-400 text-sm">—</span>}
                </td>
                <td class="px-2 sm:px-4 py-3">
                  <a href={`/admin/categorias/${cat.id}`} class="font-medium hover:text-accent transition-colors inline-flex items-center gap-1.5">
                    <span class="sm:hidden text-base leading-none">{cat.icon || ""}</span>
                    <span>{cat.name}</span>
                  </a>
                </td>
                <td class="px-4 py-3 hidden md:table-cell">
                  <span class="font-mono text-xs text-gray-600">{cat.slug}</span>
                </td>
                <td class="px-4 py-3 hidden sm:table-cell text-gray-600 text-center">
                  {cat.order}
                </td>
                <td class="px-2 sm:px-4 py-3">
                  <span
                    class={`inline-block text-xs px-2 py-0.5 rounded ${
                      cat.active
                        ? "bg-emerald-100 text-emerald-800 border border-emerald-300"
                        : "bg-gray-100 text-gray-600 border border-gray-300"
                    }`}
                  >
                    {cat.active ? "Activa" : "Inactiva"}
                  </span>
                </td>
                <td class="px-4 py-3 hidden sm:table-cell text-gray-600 text-center">
                  {count > 0 ? (
                    <span class="font-medium">{count}</span>
                  ) : (
                    <span class="text-gray-400">0</span>
                  )}
                </td>
                <td class="px-2 sm:px-4 py-3 text-right">
                  <a
                    href={`/admin/categorias/${cat.id}`}
                    class="inline-block px-2 sm:px-3 py-1 border-2 border-brand rounded hover:bg-brand hover:text-white transition-colors text-xs font-medium whitespace-nowrap"
                  >
                    Editar
                  </a>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  )}
</AdminLayout>

<script>
  import Sortable from "sortablejs";

  const tbody = document.getElementById("categories-list") as HTMLElement | null;
  const errorEl = document.getElementById("categories-error") as HTMLElement | null;

  function showError(msg: string) {
    if (!errorEl) return;
    errorEl.textContent = msg;
    errorEl.classList.remove("hidden");
  }

  function hideError() {
    if (!errorEl) return;
    errorEl.textContent = "";
    errorEl.classList.add("hidden");
  }

  async function persistOrder() {
    if (!tbody) return;
    const rows = tbody.querySelectorAll<HTMLElement>("[data-category-id]");
    const order = [...rows].map((r) => r.dataset.categoryId!).filter(Boolean);

    if (order.length === 0) return;

    try {
      const res = await fetch("/admin/api/categories/reorder", {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ order }),
      });

      if (!res.ok) {
        const data = (await res.json()) as { error?: string };
        showError(data.error ?? "Error al guardar el orden.");
      } else {
        hideError();
      }
    } catch {
      showError("Error de red al guardar el orden.");
    }
  }

  if (tbody) {
    new Sortable(tbody, {
      handle: ".category-drag-handle",
      animation: 150,
      ghostClass: "opacity-50",
      // El drag handle es un <button> que no contiene links, así que no compite
      // con los <a> de nombre/editar — SortableJS solo captura eventos en el handle.
      onEnd: () => {
        persistOrder();
      },
    });
  }
</script>
