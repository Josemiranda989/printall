---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import ProductForm from "../../../components/admin/ProductForm.astro";
import ImagesEditor from "../../../components/admin/ImagesEditor.astro";
import AttributesEditor from "../../../components/admin/AttributesEditor.astro";
import { extractProductFromForm } from "../../../lib/admin-products";
import { mapPBErrorToFieldErrors } from "../../../lib/admin-errors";
import { getFileUrl, PUBLIC_PB_URL } from "../../../lib/pocketbase";
import type { Category } from "../../../lib/types";
import type { ProductFormData } from "../../../lib/admin-products";

const pb = Astro.locals.adminPB!;
const { id } = Astro.params;
if (!id) return Astro.redirect("/admin/productos");

let record;
try {
  record = await pb.collection("products").getOne(id);
} catch {
  return new Response("Producto no encontrado", { status: 404 });
}

const categoriesRaw = await pb.collection("categories").getFullList({ sort: "order" });
const categories = categoriesRaw as unknown as Category[];

// Cargar atributos del producto para el editor
const attrsRaw = await pb.collection("product_attributes").getFullList({
  filter: `product = "${id}"`,
  sort: "+order",
});
const initialAttributes = attrsRaw.map((a: any) => ({
  id: a.id as string,
  key: a.key as string,
  value: a.value as string,
  order: (a.order as number) ?? 0,
}));

// Construir initialImages para el editor de imágenes
const rawImageFilenames = (record.images ?? []) as string[];
const initialImages = rawImageFilenames.map((filename: string) => ({
  filename,
  thumbUrl: getFileUrl(record.collectionId as string, id, filename, "120x120"),
}));

let values: Partial<ProductFormData> = {
  name: record.name,
  slug: record.slug,
  category: record.category,
  description: record.description,
  price: record.price,
  price_label: record.price_label,
  stock_status: record.stock_status,
  featured: record.featured,
  published: record.published,
};
let errors: Record<string, string> = {};
let flash: string | null = null;

const okParam = new URL(Astro.request.url).searchParams.get("ok");
if (okParam === "created") flash = "Producto creado.";
if (okParam === "saved") flash = "Cambios guardados.";

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = String(form.get("action") ?? "save");

  if (action === "delete") {
    try {
      await pb.collection("products").delete(id);
      return Astro.redirect("/admin/productos");
    } catch (err: unknown) {
      errors = mapPBErrorToFieldErrors(err, "product");
      if (!errors._global) errors._global = "No se pudo eliminar el producto.";
    }
  } else {
    const result = extractProductFromForm(form);
    values = result.data;
    errors = result.errors;

    if (Object.keys(errors).length === 0) {
      try {
        await pb.collection("products").update(id, result.data);
        return Astro.redirect(`/admin/productos/${id}?ok=saved`);
      } catch (err: unknown) {
        errors = { ...errors, ...mapPBErrorToFieldErrors(err, "product") };
      }
    }
  }
}
---

<AdminLayout title={`Editar: ${record.name}`}>
  <div class="mb-6 flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3 sm:gap-4">
    <div class="min-w-0">
      <h1 class="font-display text-2xl sm:text-3xl break-words">{record.name}</h1>
      <p class="text-xs sm:text-sm text-gray-600 mt-1 font-mono break-all">id: {id}</p>
    </div>
    <div class="flex flex-wrap items-center gap-x-4 gap-y-2 sm:flex-nowrap sm:whitespace-nowrap">
      <a
        href={`/admin/productos/${id}/preview`}
        target="_blank"
        rel="noopener"
        class="text-sm font-medium text-accent hover:underline inline-flex items-center gap-1"
        title="Ver cómo se ve este producto (incluye borradores)"
      >
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        Vista previa
      </a>
      <a
        href={`/productos/${record.slug}`}
        target="_blank"
        rel="noopener"
        class="text-sm text-accent hover:underline"
      >
        Ver en el sitio ↗
      </a>
    </div>
  </div>

  {flash && (
    <div class="border-2 border-emerald-600 bg-emerald-50 text-emerald-800 px-3 py-2 rounded-md text-sm mb-4">
      {flash}
    </div>
  )}

  <ImagesEditor
    productId={id}
    collectionId={record.collectionId as string}
    initialImages={initialImages}
    pbUrl={PUBLIC_PB_URL}
  />

  <AttributesEditor productId={id} initialAttributes={initialAttributes} />

  <ProductForm
    categories={categories}
    values={values}
    errors={errors}
    mode="edit"
    productId={id}
  />
</AdminLayout>
