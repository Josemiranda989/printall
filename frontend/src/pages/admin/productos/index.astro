---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { getFileUrl } from "../../../lib/pocketbase";
import type { Category, StockStatus } from "../../../lib/types";
import { STOCK_LABELS } from "../../../lib/types";
import {
  buildProductsFilter,
  buildPageUrl,
  parseSearchParams,
  hasFilters,
} from "../../../lib/admin-products-filter";

const pb = Astro.locals.adminPB!;

// Cantidad de productos por página (25 es razonable para el admin)
const PER_PAGE = 25;

type AdminProductRecord = {
  id: string;
  collectionId: string;
  name: string;
  slug: string;
  price: number;
  price_label: string;
  stock_status: StockStatus;
  featured: boolean;
  published: boolean;
  images: string[];
  updated: string;
  expand?: { category?: Category };
};

// Parsear filtros desde URL
const filters = parseSearchParams(Astro.url.searchParams);
const activeFilters = hasFilters(filters);
const pbFilter = buildProductsFilter(filters);

// Parsear página actual (mínimo 1, default 1)
const rawPage = Astro.url.searchParams.get("page");
const page = Math.max(1, parseInt(rawPage ?? "") || 1);

// Cargar categorías para el dropdown
const categoryRecords = await pb
  .collection("categories")
  .getFullList({ sort: "+name" });
const categories = categoryRecords as unknown as Category[];

// Cargar productos con paginación
const result = await pb.collection("products").getList(page, PER_PAGE, {
  filter: pbFilter,
  sort: "-updated",
  expand: "category",
});

const products = result.items as unknown as AdminProductRecord[];
const totalItems = result.totalItems;
const totalPages = result.totalPages;

// Rango visible: "Mostrando X-Y de N producto(s)"
const rangeStart = totalItems === 0 ? 0 : (page - 1) * PER_PAGE + 1;
const rangeEnd = Math.min(page * PER_PAGE, totalItems);

// URLs para paginación — preservan filtros activos
const prevUrl = buildPageUrl(Astro.url.searchParams, page - 1);
const nextUrl = buildPageUrl(Astro.url.searchParams, page + 1);

function thumbFor(p: AdminProductRecord): string | null {
  const first = p.images?.[0];
  if (!first) return null;
  return getFileUrl(p.collectionId, p.id, first, "120x120");
}

const inputClass =
  "mt-1 w-full rounded border-2 border-brand/40 px-3 py-2 text-sm focus:border-brand focus:outline-none bg-white";
const selectClass =
  "mt-1 w-full rounded border-2 border-brand/40 px-3 py-2 text-sm focus:border-brand focus:outline-none bg-white cursor-pointer";
const labelSpanClass = "text-xs font-medium uppercase tracking-wider text-brand/70";
---

<AdminLayout title="Productos">
  <div class="flex items-center justify-between gap-4 mb-5">
    <div>
      <h1 class="font-display text-3xl">Productos</h1>
    </div>
    <a
      href="/admin/productos/nuevo"
      class="bg-accent text-white font-medium px-4 py-2 rounded-md hover:bg-accent-hover transition-colors text-sm shrink-0"
    >
      + Nuevo producto
    </a>
  </div>

  {/* ── Formulario de filtros ── */}
  <form
    method="GET"
    class="bg-white border-2 border-brand rounded-lg p-4 mb-5 shadow-[4px_4px_0_var(--color-brand)]"
  >
    <div class="grid grid-cols-1 md:grid-cols-4 gap-3 items-end">
      <label class="block">
        <span class={labelSpanClass}>Buscar</span>
        <input
          type="text"
          name="q"
          value={filters.q ?? ""}
          placeholder="Nombre del producto…"
          class={inputClass}
        />
      </label>

      <label class="block">
        <span class={labelSpanClass}>Categoría</span>
        <select
          name="categoria"
          onchange="this.form.submit()"
          class={selectClass}
        >
          <option value="">Todas</option>
          {categories.map((c) => (
            <option
              value={c.slug}
              selected={filters.categoria === c.slug}
            >
              {c.name}
            </option>
          ))}
        </select>
      </label>

      <label class="block">
        <span class={labelSpanClass}>Stock</span>
        <select
          name="stock"
          onchange="this.form.submit()"
          class={selectClass}
        >
          <option value="">Cualquiera</option>
          <option value="in_stock" selected={filters.stock === "in_stock"}>
            {STOCK_LABELS.in_stock}
          </option>
          <option value="low_stock" selected={filters.stock === "low_stock"}>
            {STOCK_LABELS.low_stock}
          </option>
          <option
            value="out_of_stock"
            selected={filters.stock === "out_of_stock"}
          >
            {STOCK_LABELS.out_of_stock}
          </option>
          <option
            value="made_to_order"
            selected={filters.stock === "made_to_order"}
          >
            {STOCK_LABELS.made_to_order}
          </option>
        </select>
      </label>

      <label class="block">
        <span class={labelSpanClass}>Publicado</span>
        <select
          name="publicado"
          onchange="this.form.submit()"
          class={selectClass}
        >
          <option value="">Ambos</option>
          <option value="true" selected={filters.publicado === "true"}>
            Sí
          </option>
          <option value="false" selected={filters.publicado === "false"}>
            No (borradores)
          </option>
        </select>
      </label>
    </div>

    <div class="flex items-center justify-between mt-3">
      <button
        type="submit"
        class="px-4 py-2 bg-accent text-white rounded-md hover:bg-accent-hover transition-colors text-sm font-medium"
      >
        Buscar
      </button>
      {activeFilters && (
        <a
          href="/admin/productos"
          class="text-sm text-gray-500 hover:text-brand underline"
        >
          Limpiar filtros
        </a>
      )}
    </div>
  </form>

  {/* ── Indicador de resultados ── */}
  <p class="text-sm text-gray-600 mb-3">
    {totalItems === 0
      ? activeFilters
        ? "Sin resultados — filtros aplicados"
        : "Sin productos"
      : `Mostrando ${rangeStart}–${rangeEnd} de ${totalItems} ${totalItems === 1 ? "producto" : "productos"}${activeFilters ? " — filtros aplicados" : ""}`}
  </p>

  {/* ── Tabla / Empty states ── */}
  {products.length === 0 && totalItems === 0 && !activeFilters ? (
    <div class="border-2 border-dashed border-brand/30 rounded-lg p-12 text-center bg-white">
      <p class="text-gray-600 mb-4">Todavía no hay productos cargados.</p>
      <a href="/admin/productos/nuevo" class="text-accent hover:underline font-medium">
        Crear el primero →
      </a>
    </div>
  ) : products.length === 0 && totalItems === 0 && activeFilters ? (
    <div class="border-2 border-dashed border-brand/30 rounded-lg p-12 text-center bg-white">
      <p class="text-gray-600 mb-3">No hay productos que coincidan con tu búsqueda.</p>
      <a href="/admin/productos" class="text-accent hover:underline font-medium text-sm">
        Limpiar filtros →
      </a>
    </div>
  ) : products.length === 0 && page > totalPages ? (
    <div class="border-2 border-dashed border-brand/30 rounded-lg p-12 text-center bg-white">
      <p class="text-gray-600 mb-3">Esta página no tiene resultados.</p>
      <a
        href={buildPageUrl(Astro.url.searchParams, 1)}
        class="text-accent hover:underline font-medium text-sm"
      >
        Volver al inicio →
      </a>
    </div>
  ) : (
    <div class="bg-white border-2 border-brand rounded-lg overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-surface border-b-2 border-brand">
          <tr>
            <th class="text-left px-4 py-3 font-medium w-16"></th>
            <th class="text-left px-4 py-3 font-medium">Producto</th>
            <th class="text-left px-4 py-3 font-medium hidden md:table-cell">Categoría</th>
            <th class="text-left px-4 py-3 font-medium hidden md:table-cell">Precio</th>
            <th class="text-left px-4 py-3 font-medium">Estado</th>
            <th class="text-right px-4 py-3 font-medium">Acciones</th>
          </tr>
        </thead>
        <tbody>
          {products.map((p) => {
            const thumb = thumbFor(p);
            const category = p.expand?.category;
            return (
              <tr class="border-b border-brand/10 hover:bg-surface/50 transition-colors">
                <td class="px-4 py-3">
                  {thumb ? (
                    <img
                      src={thumb}
                      alt=""
                      width="40"
                      height="40"
                      class="w-10 h-10 rounded border border-brand/20 object-cover"
                      loading="lazy"
                    />
                  ) : (
                    <div class="w-10 h-10 rounded border-2 border-dashed border-brand/30 bg-surface" />
                  )}
                </td>
                <td class="px-4 py-3">
                  <div class="font-medium">{p.name}</div>
                  <div class="text-xs text-gray-500 font-mono">/{p.slug}</div>
                </td>
                <td class="px-4 py-3 hidden md:table-cell text-gray-700">
                  {category?.name ?? <span class="text-gray-400">—</span>}
                </td>
                <td class="px-4 py-3 hidden md:table-cell text-gray-700">
                  {p.price_label || (p.price > 0 ? `$${p.price.toLocaleString("es-AR")}` : "—")}
                </td>
                <td class="px-4 py-3">
                  <div class="flex flex-wrap gap-1">
                    <span
                      class={`inline-block text-xs px-2 py-0.5 rounded ${
                        p.published
                          ? "bg-emerald-100 text-emerald-800 border border-emerald-300"
                          : "bg-gray-100 text-gray-600 border border-gray-300"
                      }`}
                    >
                      {p.published ? "Publicado" : "Borrador"}
                    </span>
                    {p.featured && (
                      <span class="inline-block text-xs px-2 py-0.5 rounded bg-accent-soft text-accent-strong border border-accent/30">
                        ★ Destacado
                      </span>
                    )}
                    <span class="inline-block text-xs px-2 py-0.5 rounded bg-surface text-gray-700 border border-brand/20">
                      {STOCK_LABELS[p.stock_status] ?? p.stock_status}
                    </span>
                  </div>
                </td>
                <td class="px-4 py-3 text-right">
                  <a
                    href={`/admin/productos/${p.id}`}
                    class="inline-block px-3 py-1 border-2 border-brand rounded hover:bg-brand hover:text-white transition-colors text-xs font-medium"
                  >
                    Editar
                  </a>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  )}

  {/* ── Paginación ── solo si hay más de una página */}
  {totalPages > 1 && (
    <div class="flex items-center justify-center gap-4 mt-5">
      {page === 1 ? (
        <span
          class="px-4 py-2 border-2 border-brand/30 rounded text-sm font-medium opacity-50 pointer-events-none select-none"
          aria-disabled="true"
        >
          ← Anterior
        </span>
      ) : (
        <a
          href={prevUrl}
          class="px-4 py-2 border-2 border-brand rounded text-sm font-medium hover:bg-brand hover:text-white transition-colors"
        >
          ← Anterior
        </a>
      )}

      <span class="text-sm text-gray-600 font-medium">
        Página {page} de {totalPages}
      </span>

      {page >= totalPages ? (
        <span
          class="px-4 py-2 border-2 border-brand/30 rounded text-sm font-medium opacity-50 pointer-events-none select-none"
          aria-disabled="true"
        >
          Siguiente →
        </span>
      ) : (
        <a
          href={nextUrl}
          class="px-4 py-2 border-2 border-brand rounded text-sm font-medium hover:bg-brand hover:text-white transition-colors"
        >
          Siguiente →
        </a>
      )}
    </div>
  )}
</AdminLayout>
