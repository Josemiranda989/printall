---
import BaseLayout from "../layouts/BaseLayout.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";

const phone = import.meta.env.PUBLIC_WHATSAPP_NUMBER || "5493816563940";
const whatsappUrl = `https://wa.me/${phone}?text=${encodeURIComponent("¡Hola Print All! Me interesan sus productos.")}`;
---

<BaseLayout title="Contacto" description="Contactate con Print All por WhatsApp. Estamos en Aguilares, Tucumán.">
  <section class="bg-brand relative overflow-hidden">
    <div class="absolute inset-0 opacity-5">
      <div class="absolute -top-24 -right-24 h-80 w-80 rounded-full bg-accent blur-3xl"></div>
      <div class="absolute -bottom-32 left-0 h-64 w-64 rounded-full bg-accent blur-3xl"></div>
    </div>
    <div class="relative mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8 sm:py-16">
      <h1 class="font-display text-3xl sm:text-4xl text-white">
        Hablanos
      </h1>
      <p class="mt-2 text-white/50">Estamos a un mensaje de distancia</p>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-6 bg-[#FAFAF9]" style="clip-path: ellipse(60% 100% at 50% 100%);"></div>
  </section>

  <div class="mx-auto max-w-2xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="rounded-2xl bg-surface p-8 sm:p-10 text-center">
      <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-2xl bg-accent/10 text-4xl">
        <svg class="h-10 w-10 text-accent" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
      </div>

      <h2 class="font-display text-2xl text-brand mt-6">Contactanos por WhatsApp</h2>
      <p class="mt-3 text-brand/50 leading-relaxed">
        Respondemos rápido. Contanos qué necesitás, pedinos precio o hacenos cualquier consulta. Estamos en Aguilares, Tucumán.
      </p>

      <div class="mt-8">
        <WhatsAppButton href={whatsappUrl} />
      </div>

      <div class="mt-10 pt-8 border-t border-brand/5 grid sm:grid-cols-3 gap-6 text-center">
        <div>
          <p class="text-xs font-bold uppercase tracking-wider text-brand/25 mb-1">Seguinos</p>
          <a
            href="https://www.instagram.com/printall.tuc/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm font-medium text-accent hover:text-accent-hover transition-colors"
          >
            @printall.tuc
          </a>
        </div>
        <div>
          <p class="text-xs font-bold uppercase tracking-wider text-brand/25 mb-1">Ubicación</p>
          <p class="text-sm text-brand/50">Aguilares, Tucumán</p>
        </div>
        <div>
          <p class="text-xs font-bold uppercase tracking-wider text-brand/25 mb-1">Horario</p>
          <p class="text-sm text-brand/50">Lun a Vie</p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
