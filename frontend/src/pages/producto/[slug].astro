---
import BaseLayout from "../../layouts/BaseLayout.astro";
import StockBadge from "../../components/StockBadge.astro";
import WhatsAppButton from "../../components/WhatsAppButton.astro";
import { getProductBySlug, getProductWhatsAppUrl } from "../../lib/pocketbase";

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/productos");
const product = await getProductBySlug(slug);

if (!product) {
  return Astro.redirect("/productos");
}

const category = product.expand?.category;
const whatsappUrl = getProductWhatsAppUrl(product);
const allImages = product.images?.length ? product.images : [];
const firstThumb = allImages[0]?.thumbnails?.["800x800"] ?? "/logo.png";
---

<BaseLayout
  title={product.name}
  description={product.description?.replace(/<[^>]*>/g, "").slice(0, 160)}
  ogImage={firstThumb}
>
  <div class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8 sm:py-12">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-brand/40 mb-6">
      <a href="/" class="hover:text-accent transition-colors">Inicio</a>
      <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
      </svg>
      <a href="/productos" class="hover:text-accent transition-colors">Productos</a>
      {category && (
        <>
          <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
          </svg>
          <a href={`/productos/${category.slug}`} class="hover:text-accent transition-colors">{category.name}</a>
        </>
      )}
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
      <!-- Galería -->
      <div>
        <div
          id="main-image-wrapper"
          class="aspect-square overflow-hidden rounded-2xl bg-surface border border-surface cursor-pointer relative group/image"
        >
          <img
            id="main-image"
            src={firstThumb}
            alt={product.name}
            class="h-full w-full object-cover transition-transform duration-500 group-hover/image:scale-105"
            width="800"
            height="800"
          />
          <!-- Lupa overlay -->
          <div class="absolute inset-0 bg-black/0 group-hover/image:bg-black/5 transition-all duration-300 flex items-center justify-center">
            <div class="opacity-0 group-hover/image:opacity-100 transition-all duration-300 bg-white/90 backdrop-blur-sm rounded-full px-3 py-1.5 text-xs font-semibold text-brand flex items-center gap-1.5 shadow-lg">
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607zM10.5 7.5v6m3-3h-6" />
              </svg>
              Ampliar
            </div>
          </div>
        </div>

        {allImages.length > 1 && (
          <div class="mt-4 grid grid-cols-4 gap-3" id="thumbnail-grid">
            {allImages.map((img, i) => (
              <button
                type="button"
                class={`aspect-square overflow-hidden rounded-xl border-2 transition-all cursor-pointer ${
                  i === 0
                    ? "border-accent"
                    : "border-surface hover:border-accent/40"
                }`}
                data-thumb-url={img.thumbnails["800x800"]}
                data-full-url={img.url}
                data-index={i}
              >
                <img
                  src={img.thumbnails["120x120"]}
                  alt={`${product.name} - ${i + 1}`}
                  class="h-full w-full object-cover"
                  width="120"
                  height="120"
                  loading="lazy"
                />
              </button>
            ))}
          </div>
        )}
      </div>

      <!-- Info -->
      <div class="flex flex-col">
        <div class="flex items-start justify-between gap-3 mb-3">
          <div>
            {category && (
              <a
                href={`/productos/${category.slug}`}
                class="text-sm font-medium text-accent hover:text-accent-hover transition-colors"
              >
                {category.icon} {category.name}
              </a>
            )}
            <h1 class="font-display text-2xl sm:text-3xl text-brand mt-1 leading-tight">
              {product.name}
            </h1>
          </div>
          {product.featured && (
            <span class="shrink-0 text-[10px] font-bold uppercase tracking-wider text-accent bg-accent-soft rounded-full px-3 py-1">
              Destacado
            </span>
          )}
        </div>

        <StockBadge status={product.stock_status} class="w-fit" />

        <div class="mt-6">
          {product.price ? (
            <div class="flex items-baseline gap-2">
              <span class="font-display text-3xl text-brand">
                ${product.price.toLocaleString("es-AR")}
              </span>
              {product.price_label && (
                <span class="text-sm text-brand/40">{product.price_label}</span>
              )}
            </div>
          ) : (
            <span class="text-xl font-semibold text-brand/50">Consultar precio</span>
          )}
        </div>

        {product.description && (
          <div class="mt-6 prose prose-sm max-w-none text-brand/60 leading-relaxed">
            <Fragment set:html={product.description} />
          </div>
        )}

        {product.attributes && Object.keys(product.attributes).length > 0 && (
          <div class="mt-6 border-t border-surface pt-6">
            <h3 class="text-sm font-semibold text-brand mb-3">Especificaciones</h3>
            <dl class="grid grid-cols-2 gap-3">
              {Object.entries(product.attributes).map(([key, value]) => (
                <div class="rounded-lg bg-surface px-3 py-2">
                  <dt class="text-[10px] font-bold uppercase tracking-wider text-brand/30">{key}</dt>
                  <dd class="text-sm font-medium text-brand mt-0.5">{String(value)}</dd>
                </div>
              ))}
            </dl>
          </div>
        )}

        <div class="mt-8 border-t border-surface pt-6">
          <WhatsAppButton href={whatsappUrl} />
        </div>
      </div>
    </div>
  </div>

  <!-- Lightbox overlay -->
  <div
    id="lightbox"
    class="fixed inset-0 z-50 bg-black/90 backdrop-blur-sm hidden items-center justify-center"
    data-lightbox
    data-product-name={product.name}
    data-images={JSON.stringify(allImages.map(img => ({
      full: img.url,
      thumb: img.thumbnails?.["800x800"] ?? img.url
    })))}
  >
    <!-- Close button -->
    <button
      type="button"
      id="lightbox-close"
      class="absolute top-4 right-4 z-10 text-white/60 hover:text-white transition-colors p-2"
      aria-label="Cerrar"
    >
      <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <!-- Counter -->
    <div class="absolute top-4 left-4 text-white/40 text-sm font-medium" id="lightbox-counter"></div>

    <!-- Prev -->
    <button
      type="button"
      id="lightbox-prev"
      class="absolute left-4 top-1/2 -translate-y-1/2 text-white/60 hover:text-white transition-colors p-2"
      aria-label="Anterior"
    >
      <svg class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
      </svg>
    </button>

    <!-- Image -->
    <img
      id="lightbox-image"
      src=""
      alt=""
      class="max-h-[90vh] max-w-[90vw] object-contain rounded-lg"
    />

    <!-- Next -->
    <button
      type="button"
      id="lightbox-next"
      class="absolute right-4 top-1/2 -translate-y-1/2 text-white/60 hover:text-white transition-colors p-2"
      aria-label="Siguiente"
    >
      <svg class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
      </svg>
    </button>
  </div>
</BaseLayout>

<style is:global>
  #lightbox {
    transition: opacity 0.25s ease;
  }
  #lightbox:not(.hidden) {
    opacity: 1;
  }
  #lightbox.hidden {
    opacity: 0;
    pointer-events: none;
  }
  #lightbox-image {
    transition: opacity 0.2s ease;
  }
  #lightbox-image.loading {
    opacity: 0;
  }
</style>

<script>
  const lightbox = document.getElementById("lightbox")!;
  const lightboxImg = document.getElementById("lightbox-image") as HTMLImageElement | null;
  const lightboxClose = document.getElementById("lightbox-close");
  const lightboxPrev = document.getElementById("lightbox-prev");
  const lightboxNext = document.getElementById("lightbox-next");
  const lightboxCounter = document.getElementById("lightbox-counter");

  const productName = lightbox.dataset.productName ?? "";
  const rawImages = lightbox.dataset.images;
  const images: { thumb: string; full: string }[] = rawImages
    ? JSON.parse(rawImages)
    : [];

  let currentIndex = 0;

  // If no images array from data, build from thumbnails as fallback
  const mainImage = document.getElementById("main-image") as HTMLImageElement | null;
  const mainWrapper = document.getElementById("main-image-wrapper");
  const thumbGrid = document.getElementById("thumbnail-grid");

  if (images.length === 0 && mainImage?.src) {
    images.push({ thumb: mainImage.src, full: mainImage.src });
  }

  function openLightbox(index: number) {
    if (images.length === 0) return;
    currentIndex = index;
    showImage(currentIndex);
    lightbox.classList.remove("hidden");
    lightbox.classList.add("flex");
    document.body.style.overflow = "hidden";
  }

  function closeLightbox() {
    lightbox.classList.add("hidden");
    lightbox.classList.remove("flex");
    document.body.style.overflow = "";
  }

  function showImage(index: number) {
    if (!lightboxImg || images.length === 0) return;
    const img = images[index];
    if (!img) return;

    lightboxImg.classList.add("loading");
    lightboxImg.src = img.full;
    lightboxImg.alt = `${productName} - ${index + 1}`;

    if (lightboxCounter) {
      lightboxCounter.textContent = `${index + 1} / ${images.length}`;
    }

    // Highlight active thumbnail
    if (thumbGrid) {
      const thumbs = thumbGrid.querySelectorAll("[data-index]");
      thumbs.forEach((t, i) => {
        t.classList.toggle("border-accent", i === index);
        t.classList.toggle("border-surface", i !== index);
      });
    }

    // Sync main image
    if (mainImage && img.thumb) {
      mainImage.src = img.thumb;
    }
  }

  if (lightboxImg) {
    lightboxImg.addEventListener("load", () => {
      lightboxImg.classList.remove("loading");
    });
  }

  function prevImage() {
    if (images.length === 0) return;
    currentIndex = (currentIndex - 1 + images.length) % images.length;
    showImage(currentIndex);
  }

  function nextImage() {
    if (images.length === 0) return;
    currentIndex = (currentIndex + 1) % images.length;
    showImage(currentIndex);
  }

  // --- Eventos ---

  mainWrapper?.addEventListener("click", () => {
    const activeThumb = thumbGrid?.querySelector("[data-index].border-accent");
    const idx = activeThumb
      ? parseInt((activeThumb as HTMLElement).dataset.index ?? "0")
      : 0;
    openLightbox(idx);
  });

  if (thumbGrid) {
    thumbGrid.addEventListener("click", (e: Event) => {
      const target = e.target as HTMLElement;
      const btn = target.closest("[data-thumb-url]") as HTMLElement | null;
      if (!btn) return;

      const url = btn.dataset.thumbUrl;
      if (mainImage && url) {
        mainImage.src = url;
      }

      thumbGrid.querySelectorAll("[data-index]").forEach((t) => {
        t.classList.remove("border-accent");
        t.classList.add("border-surface");
      });
      btn.classList.remove("border-surface");
      btn.classList.add("border-accent");
    });
  }

  lightboxClose?.addEventListener("click", closeLightbox);
  lightboxPrev?.addEventListener("click", prevImage);
  lightboxNext?.addEventListener("click", nextImage);

  lightbox.addEventListener("click", (e: Event) => {
    if (e.target === lightbox) closeLightbox();
  });

  document.addEventListener("keydown", (e: KeyboardEvent) => {
    if (lightbox.classList.contains("hidden")) return;
    if (e.key === "Escape") closeLightbox();
    if (e.key === "ArrowLeft") prevImage();
    if (e.key === "ArrowRight") nextImage();
  });
</script>
