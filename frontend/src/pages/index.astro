---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProductCard from "../components/ProductCard.astro";
import { getProducts, getCategories } from "../lib/pocketbase";

const [allProducts, categories] = await Promise.all([
  getProducts(),
  getCategories(),
]);
---

<BaseLayout
  title="Catálogo"
  description="Catálogo online de Print All — impresión 3D en Aguilares, Tucumán. Filamentos, mates, vasos, llaveros y más."
>
  <!-- Hero compacto -->
  <section class="bg-brand relative overflow-hidden">
    <div class="absolute inset-0 opacity-5">
      <div class="absolute -top-24 -right-24 h-96 w-96 rounded-full bg-accent blur-3xl"></div>
      <div class="absolute -bottom-32 -left-32 h-80 w-80 rounded-full bg-accent blur-3xl"></div>
    </div>

    <div class="relative mx-auto max-w-6xl px-4 py-14 sm:px-6 lg:px-8 sm:py-20">
      <div class="max-w-2xl">
        <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl text-white leading-[0.95] tracking-tight">
          Todo lo que
          <span class="text-accent block">imaginás, lo imprimimos</span>
        </h1>
        <p class="mt-4 text-base sm:text-lg text-white/60 max-w-lg leading-relaxed">
          Impresión 3D en Aguilares, Tucumán. Productos personalizados, filamentos premium y más.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a
            href="#catalogo"
            class="inline-flex items-center gap-2 rounded-full bg-accent px-6 py-3 text-sm font-semibold text-white hover:bg-accent-hover hover:shadow-lg hover:shadow-accent/25 transition-all duration-300 hover:-translate-y-0.5"
          >
            Ver catálogo
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
            </svg>
          </a>
          <a
            href="/contacto"
            class="inline-flex items-center gap-2 rounded-full border-2 border-white/20 px-6 py-3 text-sm font-semibold text-white hover:bg-white/10 hover:border-white/30 transition-all duration-300"
          >
            Contacto
          </a>
        </div>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0 h-6 bg-[#FAFAF9]" style="clip-path: ellipse(60% 100% at 50% 100%);"></div>
  </section>

  <!-- Catálogo -->
  <section id="catalogo" class="mx-auto max-w-6xl px-4 pb-12 sm:px-6 lg:px-8 sm:pb-16">
    <!-- Sticky: header + buscador + filtros -->
    <div class="sticky top-0 z-30 bg-[#FAFAF9]/80 backdrop-blur-lg -mx-4 px-4 sm:-mx-6 sm:px-6 lg:-mx-8 lg:px-8 pt-6 sm:pt-8 pb-4 border-b border-brand/5">
      <div class="mb-2">
        <span class="text-xs font-bold uppercase tracking-[0.2em] text-accent">Catálogo</span>
        <h2 class="font-display text-3xl text-brand mt-1">Nuestros productos</h2>
      </div>

      <!-- Buscador -->
      <div class="relative mt-4">
        <svg class="pointer-events-none absolute left-3.5 top-1/2 -translate-y-1/2 h-4 w-4 text-brand/25" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
        </svg>
        <input
          type="text"
          id="search-input"
          placeholder="Buscar producto…"
          class="w-full rounded-xl border-2 border-brand/10 bg-surface/60 px-4 py-2.5 pl-10 pr-10 text-sm text-brand placeholder:text-brand/25 focus:outline-none focus:border-accent/50 focus:bg-surface focus:shadow-sm transition-all duration-200"
        />
        <button
          type="button"
          id="search-clear"
          class="absolute right-3 top-1/2 -translate-y-1/2 text-brand/20 hover:text-brand/40 transition-colors hidden"
          aria-label="Limpiar búsqueda"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <!-- Pills de filtro -->
      <div
        class="flex gap-2 overflow-x-auto pt-3 pb-1 scrollbar-none relative"
        style="scrollbar-width: none; -ms-overflow-style: none;"
        data-filter-bar
      >
        <!-- Gradient hint (mobile) -->
        <div
          class="sticky right-0 w-10 h-full bg-gradient-to-l from-[#FAFAF9] to-transparent pointer-events-none shrink-0 md:hidden -mr-2 ml-auto"
          data-scroll-hint
        ></div>

        <button
          data-category="all"
          class="filter-pill active shrink-0 rounded-full border-2 px-4 py-1.5 text-sm font-medium transition-all duration-200"
        >
          Todos
          <span class="ml-1.5 text-xs opacity-60">({allProducts.length})</span>
        </button>
        {categories.map((cat) => {
          const count = allProducts.filter(
            (p) => p.expand?.category?.slug === cat.slug
          ).length;
          return (
            <button
              data-category={cat.slug}
              class="filter-pill shrink-0 rounded-full border-2 px-4 py-1.5 text-sm font-medium transition-all duration-200 flex items-center gap-1.5"
            >
              <span>{cat.icon}</span>
              {cat.name}
              <span class="text-xs opacity-60">({count})</span>
            </button>
          );
        })}
      </div>
    </div>

    <!-- Contador -->
    <p class="mt-6 text-sm text-brand/40" data-product-count>
      {allProducts.length} producto{allProducts.length !== 1 ? "s" : ""}
    </p>

    <!-- Grid -->
    <div
      class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 sm:gap-5 mt-4"
      data-product-grid
    >
      {allProducts.map((product) => (
        <div
          class="product-card"
          data-category={product.expand?.category?.slug ?? ""}
          data-name={product.name.toLowerCase()}
        >
          <ProductCard product={product} />
        </div>
      ))}
    </div>

    <!-- Empty state -->
    <div class="text-center py-20 hidden" data-empty-state>
      <svg class="h-12 w-12 mx-auto text-brand/10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />
      </svg>
      <p class="text-brand/30 text-lg mt-4" data-empty-message>No se encontraron productos</p>
      <button
        type="button"
        id="reset-filters"
        class="mt-4 text-sm text-accent hover:text-accent-hover font-medium transition-colors"
      >
        Limpiar filtros
      </button>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand relative overflow-hidden">
    <div class="absolute inset-0 opacity-5">
      <div class="absolute top-0 right-0 h-64 w-64 rounded-full bg-accent blur-3xl"></div>
    </div>
    <div class="relative mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display text-3xl sm:text-4xl text-white">¿Tenés una idea?</h2>
      <p class="mt-4 text-lg text-white/60 max-w-lg mx-auto">
        Contanos qué querés imprimir y lo hacemos realidad. Hacenos tu consulta sin compromiso.
      </p>
      <a
        href="/contacto"
        class="inline-flex items-center gap-2 mt-8 rounded-full bg-accent px-8 py-3.5 text-base font-semibold text-white hover:bg-accent-hover hover:shadow-xl hover:shadow-accent/30 transition-all duration-300 hover:-translate-y-0.5"
      >
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Hablar por WhatsApp
      </a>
    </div>
  </section>
</BaseLayout>

<style is:global>
  .filter-pill {
    border-color: color-mix(in srgb, var(--color-brand), transparent 90%);
    color: color-mix(in srgb, var(--color-brand), transparent 50%);
    background: transparent;
    cursor: pointer;
    user-select: none;
    white-space: nowrap;
  }
  .filter-pill:hover {
    border-color: color-mix(in srgb, var(--color-accent), transparent 70%);
    color: var(--color-brand);
    background: color-mix(in srgb, var(--color-accent), transparent 95%);
  }
  .filter-pill.active {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: var(--color-accent-soft);
  }

  .product-card {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .product-card.hidden-product {
    display: none;
  }

  @keyframes cardEnter {
    from {
      opacity: 0;
      transform: translateY(16px) scale(0.95);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
  .product-card.entering {
    animation: cardEnter 0.35s ease both;
    animation-delay: var(--enter-delay, 0ms);
  }
</style>

<script>
  const filterBar = document.querySelector("[data-filter-bar]")!;
  const grid = document.querySelector("[data-product-grid]");
  const productCards = grid?.querySelectorAll("[data-category]")!;
  const countEl = document.querySelector("[data-product-count]")!;
  const searchInput = document.querySelector("#search-input") as HTMLInputElement | null;
  const searchClear = document.querySelector("#search-clear") as HTMLElement | null;
  const emptyState = document.querySelector("[data-empty-state]") as HTMLElement | null;
  const resetBtn = document.querySelector("#reset-filters") as HTMLElement | null;
  const scrollHint = document.querySelector("[data-scroll-hint]") as HTMLElement | null;

  let activeCategory = "all";
  let searchQuery = "";
  let searchTimeout: number;

  function filterProducts(category: string) {
    activeCategory = category;
    filterBar.querySelectorAll("[data-category]").forEach((btn) => {
      const button = btn as HTMLElement;
      button.classList.toggle("active", button.dataset.category === category);
    });
    applyFilters();
  }

  function applyFilters() {
    let visibleCount = 0;
    let animIndex = 0;

    productCards.forEach((el) => {
      const element = el as HTMLElement;
      const matchCategory =
        activeCategory === "all" || element.dataset.category === activeCategory;
      const matchSearch =
        !searchQuery || (element.dataset.name || "").includes(searchQuery);
      const match = matchCategory && matchSearch;

      element.classList.remove("entering");
      element.style.removeProperty("--enter-delay");

      if (match) {
        const wasHidden = element.classList.contains("hidden-product");
        element.classList.remove("hidden-product");

        if (wasHidden) {
          element.style.setProperty("--enter-delay", `${animIndex * 35}ms`);
          void element.offsetHeight;
          element.classList.add("entering");
        }
        visibleCount++;
        animIndex++;
      } else {
        element.classList.add("hidden-product");
        element.classList.remove("entering");
      }
    });

    const label = visibleCount === 1 ? "producto" : "productos";
    countEl.textContent = `${visibleCount} ${label}`;

    if (emptyState) {
      emptyState.classList.toggle("hidden", visibleCount > 0);
    }
    if (searchClear) {
      searchClear.classList.toggle("hidden", !searchQuery);
    }

    const url = new URL(window.location.href);
    if (activeCategory === "all") {
      url.searchParams.delete("categoria");
    } else {
      url.searchParams.set("categoria", activeCategory);
    }
    if (searchQuery) {
      url.searchParams.set("q", searchQuery);
    } else {
      url.searchParams.delete("q");
    }
    window.history.replaceState({}, "", url);
  }

  // --- Init from URL ---
  const params = new URLSearchParams(window.location.search);
  const initialCategory = params.get("categoria");
  const initialSearch = params.get("q");

  if (initialSearch && searchInput) {
    searchInput.value = initialSearch;
    searchQuery = initialSearch.toLowerCase();
  }

  if (initialCategory) {
    const validPill = filterBar.querySelector(
      `[data-category="${initialCategory}"]`
    ) as HTMLElement | null;
    if (validPill) {
      filterBar.querySelector('[data-category="all"]')?.classList.remove("active");
      validPill.classList.add("active");
      activeCategory = initialCategory;
    }
  }

  applyFilters();

  // --- Click en pills ---
  filterBar.addEventListener("click", (e: Event) => {
    const target = e.target as HTMLElement;
    const btn = target.closest("[data-category]") as HTMLElement | null;
    if (btn) {
      filterProducts(btn.dataset.category ?? "all");
    }
  });

  // --- Search (debounced) ---
  if (searchInput) {
    searchInput.addEventListener("input", () => {
      clearTimeout(searchTimeout);
      searchTimeout = window.setTimeout(() => {
        searchQuery = searchInput.value.toLowerCase().trim();
        applyFilters();
      }, 150);
    });
  }

  // --- Clear search ---
  if (searchClear) {
    searchClear.addEventListener("click", () => {
      if (searchInput) {
        searchInput.value = "";
        searchQuery = "";
        searchInput.focus();
        applyFilters();
      }
    });
  }

  // --- Reset all ---
  if (resetBtn) {
    resetBtn.addEventListener("click", () => {
      if (searchInput) searchInput.value = "";
      searchQuery = "";
      filterProducts("all");
      grid?.scrollIntoView({ behavior: "smooth", block: "start" });
    });
  }

  // --- Scroll hint detection ---
  if (scrollHint) {
    function checkScroll() {
      const hint = scrollHint;
      if (!hint) return;
      const hasScroll = filterBar.scrollWidth > filterBar.clientWidth;
      hint.classList.toggle("hidden", !hasScroll);
    }
    checkScroll();
    window.addEventListener("resize", checkScroll);
  }
</script>
