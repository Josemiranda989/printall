---
const navLinks = [
  { href: "/", label: "Inicio" },
  { href: "/productos", label: "Productos" },
  { href: "/contacto", label: "Contacto" },
];

const currentPath = Astro.url.pathname;

const whatsappPhone = import.meta.env.PUBLIC_WHATSAPP_NUMBER || "5493816563940";
const whatsappMessage = encodeURIComponent("¡Hola Print All! 👋");
const whatsappUrl = `https://wa.me/${whatsappPhone}?text=${whatsappMessage}`;
---

<header
  class="site-header sticky top-0 z-50 bg-brand/80 backdrop-blur-xl border-b border-white/[0.06]"
>
  <!-- Acento naranja inferior -->
  <div class="pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-accent/40 to-transparent"></div>

  <nav class="relative mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 sm:px-6 lg:px-8">
    <!-- Logo -->
    <a
      href="/"
      class="flex items-center shrink-0 group"
      aria-label="Print All — Inicio"
    >
      <img
        src="/logo.webp"
        alt="Print All"
        class="h-9 w-auto transition-transform duration-300 ease-out group-hover:rotate-[-2deg] group-hover:scale-[1.02]"
        width="146"
        height="90"
      />
    </a>

    <!-- Nav desktop -->
    <ul class="hidden md:flex items-center gap-1">
      {
        navLinks.map((link) => {
          const isActive =
            link.href === "/"
              ? currentPath === "/"
              : currentPath.startsWith(link.href);

          return (
            <li>
              <a
                href={link.href}
                class={`nav-link relative inline-flex items-center px-3 py-2 text-[12px] font-bold uppercase tracking-[0.16em] transition-colors duration-200 ${
                  isActive
                    ? "text-white"
                    : "text-white/55 hover:text-white"
                }`}
              >
                {link.label}
                {isActive && (
                  <span class="absolute left-3 right-3 -bottom-0.5 h-[2px] rounded-full bg-accent"></span>
                )}
              </a>
            </li>
          );
        })
      }
    </ul>

    <!-- CTA + Mobile trigger -->
    <div class="flex items-center gap-2">
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden sm:inline-flex items-center gap-2 rounded-full bg-accent/10 hover:bg-accent text-accent hover:text-white border border-accent/30 hover:border-accent px-3.5 py-1.5 text-[11px] font-bold uppercase tracking-[0.16em] transition-all duration-200 hover:shadow-lg hover:shadow-accent/20"
        aria-label="Contactar por WhatsApp"
      >
        <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Hablar
      </a>

      <button
        type="button"
        class="mobile-menu-btn md:hidden inline-flex items-center justify-center rounded-lg p-2 text-white/70 hover:text-white hover:bg-white/10 transition-colors"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
        data-mobile-menu-trigger
      >
        <svg class="icon-open h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg class="icon-close h-5 w-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu (slide-down) -->
  <div
    id="mobile-menu"
    class="mobile-menu md:hidden overflow-hidden max-h-0 transition-[max-height] duration-300 ease-out border-t border-white/[0.04]"
    data-mobile-menu
  >
    <ul class="flex flex-col gap-1 px-4 pt-3 pb-5 sm:px-6">
      {
        navLinks.map((link) => {
          const isActive =
            link.href === "/"
              ? currentPath === "/"
              : currentPath.startsWith(link.href);

          return (
            <li>
              <a
                href={link.href}
                class={`flex items-center justify-between rounded-xl px-4 py-3 text-sm font-bold uppercase tracking-[0.16em] transition-colors ${
                  isActive
                    ? "bg-accent/15 text-accent border border-accent/30"
                    : "text-white/70 hover:text-white hover:bg-white/5 border border-transparent"
                }`}
              >
                {link.label}
                <svg class="h-4 w-4 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            </li>
          );
        })
      }
      <li class="mt-2">
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center gap-2 rounded-xl bg-accent text-white px-4 py-3 text-sm font-bold uppercase tracking-[0.16em] hover:bg-accent-hover transition-colors shadow-lg shadow-accent/20"
        >
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Hablar por WhatsApp
        </a>
      </li>
    </ul>
  </div>
</header>

<style>
  /* Sombra sutil cuando se hace scroll */
  .site-header.scrolled {
    box-shadow: 0 6px 20px -10px rgba(0, 0, 0, 0.55);
  }
</style>

<script>
  // --- Mobile menu toggle ---
  const trigger = document.querySelector(
    "[data-mobile-menu-trigger]"
  ) as HTMLButtonElement | null;
  const menu = document.querySelector(
    "[data-mobile-menu]"
  ) as HTMLElement | null;
  const iconOpen = trigger?.querySelector(".icon-open") as HTMLElement | null;
  const iconClose = trigger?.querySelector(".icon-close") as HTMLElement | null;

  function setMenu(open: boolean) {
    if (!trigger || !menu) return;
    trigger.setAttribute("aria-expanded", String(open));
    trigger.setAttribute("aria-label", open ? "Cerrar menú" : "Abrir menú");
    menu.style.maxHeight = open ? menu.scrollHeight + "px" : "0";
    iconOpen?.classList.toggle("hidden", open);
    iconClose?.classList.toggle("hidden", !open);
  }

  trigger?.addEventListener("click", () => {
    const open = trigger.getAttribute("aria-expanded") === "true";
    setMenu(!open);
  });

  // Cerrar al hacer click en un link
  menu?.querySelectorAll("a").forEach((a) =>
    a.addEventListener("click", () => setMenu(false))
  );

  // Cerrar al pasar a desktop
  const mq = window.matchMedia("(min-width: 768px)");
  mq.addEventListener("change", (e) => {
    if (e.matches) setMenu(false);
  });

  // --- Sombra al scrollear ---
  const header = document.querySelector(".site-header");
  if (header) {
    const handleScroll = () => {
      header.classList.toggle("scrolled", window.scrollY > 8);
    };
    handleScroll();
    window.addEventListener("scroll", handleScroll, { passive: true });
  }
</script>
