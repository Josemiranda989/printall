---
import type { Category } from "../lib/types";

interface Props {
  category: Category;
}
const { category } = Astro.props;
---

<a
  href={`/productos/${category.slug}`}
  class="group flex items-center gap-4 rounded-xl bg-surface p-5 border border-transparent hover:border-accent/20 hover:shadow-md hover:shadow-brand/5 hover:-translate-y-0.5 transition-all duration-300"
>
  <div
    class="flex h-14 w-14 shrink-0 items-center justify-center rounded-xl bg-brand/5 text-2xl group-hover:scale-110 transition-transform duration-300"
  >
    {category.icon}
  </div>

  <div class="flex-1 min-w-0">
    <h3 class="font-semibold text-text text-sm group-hover:text-accent transition-colors">
      {category.name}
    </h3>
    {category.description && (
      <p class="mt-0.5 text-xs text-brand/60 line-clamp-2">{category.description}</p>
    )}
  </div>

  <div class="h-8 w-8 rounded-full bg-accent/10 flex items-center justify-center text-accent opacity-0 group-hover:opacity-100 transition-all duration-300 translate-x-1 group-hover:translate-x-0">
    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
    </svg>
  </div>
</a>
