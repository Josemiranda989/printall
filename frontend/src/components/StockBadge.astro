---
import type { StockStatus } from "../lib/types";
import { STOCK_LABELS, STOCK_COLORS } from "../lib/types";

interface Props {
  status: StockStatus;
  class?: string;
}

const { status, class: className } = Astro.props;
const color = STOCK_COLORS[status] ?? "bg-gray-400";
const label = STOCK_LABELS[status] ?? status;
---

<span
  class={`inline-flex items-center gap-1.5 rounded-full px-2.5 py-0.5 text-xs font-medium text-white ${color} ${className ?? ""}`}
>
  <span class="inline-block h-1.5 w-1.5 rounded-full bg-white/80" aria-hidden="true"></span>
  {label}
</span>
