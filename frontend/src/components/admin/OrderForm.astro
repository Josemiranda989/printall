---
import {
  COLOR_LABELS,
  COLOR_VALUES,
  COLOR_HEX,
  MATERIAL_LABELS,
  MATERIAL_VALUES,
  ORDER_STATUS_LABELS,
  ORDER_STATUS_VALUES,
  PRIORITY_LABELS,
  PRIORITY_VALUES,
} from "../../lib/types";
import { getWhatsAppUrl } from "../../lib/pocketbase";
import {
  CUSTOMER_NAME_MAX,
  CUSTOMER_WHATSAPP_MAX,
  NOTES_MAX,
  PROJECT_NAME_MAX,
  type OrderFormData,
} from "../../lib/admin-orders";
import type { ClientForAutocomplete } from "../../lib/admin-clients";

export interface Props {
  values: Partial<OrderFormData>;
  errors?: Record<string, string>;
  mode: "create" | "edit";
  orderId?: string;
  clients?: ClientForAutocomplete[];
}

const { values, errors = {}, mode, orderId, clients = [] } = Astro.props;

const fieldClass =
  "mt-1 block w-full border-2 border-brand rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-accent disabled:bg-gray-100";
const sectionClass =
  "bg-white border-2 border-brand rounded-lg p-5 space-y-5 shadow-[4px_4px_0_var(--color-brand)]";

function errorMsg(field: string) {
  return errors[field];
}

/** ISO string → "YYYY-MM-DDTHH:mm" para <input type="datetime-local">. */
function toLocalDatetimeInput(iso: string | undefined | null): string {
  if (!iso) return "";
  const d = new Date(iso);
  if (isNaN(d.getTime())) return "";
  const pad = (n: number) => String(n).padStart(2, "0");
  return (
    d.getFullYear() +
    "-" +
    pad(d.getMonth() + 1) +
    "-" +
    pad(d.getDate()) +
    "T" +
    pad(d.getHours()) +
    ":" +
    pad(d.getMinutes())
  );
}

/** ISO string → "YYYY-MM-DD" para <input type="date">. */
function toDateInput(iso: string | undefined | null): string {
  if (!iso) return "";
  const d = new Date(iso);
  if (isNaN(d.getTime())) return "";
  const pad = (n: number) => String(n).padStart(2, "0");
  return d.getFullYear() + "-" + pad(d.getMonth() + 1) + "-" + pad(d.getDate());
}

const orderDateValue = toLocalDatetimeInput(values.order_date);
const deliveryDateValue = toDateInput(values.delivery_date);

// WhatsApp link: si hay teléfono cargado, armar link al chat.
const phone = (values.customer_whatsapp ?? "").replace(/[^\d+]/g, "");
const whatsappUrl =
  phone && values.customer_name
    ? getWhatsAppUrl(
        phone.replace(/^\+/, ""),
        `¡Hola ${values.customer_name}! 👋`,
      )
    : null;
---

<form method="POST" class="space-y-5">
  {errors._global && (
    <div class="border-2 border-red-500 bg-red-50 text-red-800 px-3 py-2 rounded-md text-sm">
      {errors._global}
    </div>
  )}

  {/* ─── Sección 1: Proyecto ─── */}
  <section class={sectionClass}>
    <h2 class="font-display text-lg border-b-2 border-brand/20 pb-2">Proyecto</h2>

    <label class="block">
      <span class="text-sm font-medium">Nombre del proyecto *</span>
      <input
        type="text"
        name="project_name"
        required
        maxlength={PROJECT_NAME_MAX}
        value={values.project_name ?? ""}
        placeholder="Ej: Soporte celular vertical"
        class={fieldClass}
      />
      {errorMsg("project_name") && (
        <p class="text-xs text-red-600 mt-1">{errorMsg("project_name")}</p>
      )}
    </label>

    <div>
      <span class="text-sm font-medium block mb-2">Prioridad</span>
      <div class="flex gap-2 flex-wrap">
        {PRIORITY_VALUES.map((p) => (
          <label class="cursor-pointer">
            <input
              type="radio"
              name="priority"
              value={p}
              checked={(values.priority ?? "medium") === p}
              class="sr-only peer"
            />
            <span
              class={`inline-block px-4 py-2 border-2 rounded-md text-sm font-medium transition-colors border-brand/30 text-brand peer-checked:bg-brand peer-checked:text-white peer-checked:border-brand hover:border-brand`}
            >
              {PRIORITY_LABELS[p]}
            </span>
          </label>
        ))}
      </div>
      {errorMsg("priority") && (
        <p class="text-xs text-red-600 mt-1">{errorMsg("priority")}</p>
      )}
    </div>
  </section>

  {/* ─── Sección 2: Cliente ─── */}
  <section class={sectionClass}>
    <h2 class="font-display text-lg border-b-2 border-brand/20 pb-2">Cliente</h2>

    <label class="block">
      <span class="text-sm font-medium">Nombre *</span>
      <input
        type="text"
        name="customer_name"
        required
        maxlength={CUSTOMER_NAME_MAX}
        value={values.customer_name ?? ""}
        list="client-autocomplete-list"
        autocomplete="off"
        data-customer-name
        class={fieldClass}
      />
      {clients.length > 0 && (
        <datalist id="client-autocomplete-list">
          {clients.map((c) => (
            <option value={c.name} data-whatsapp={c.whatsapp}>
              {c.whatsapp ? `${c.name} · ${c.whatsapp}` : c.name}
            </option>
          ))}
        </datalist>
      )}
      {clients.length > 0 && (
        <p class="text-xs text-gray-500 mt-1">
          Tipeá para buscar entre {clients.length} clientes existentes, o cargá uno nuevo.
        </p>
      )}
      {errorMsg("customer_name") && (
        <p class="text-xs text-red-600 mt-1">{errorMsg("customer_name")}</p>
      )}
    </label>

    <label class="block">
      <div class="flex items-center justify-between gap-2">
        <span class="text-sm font-medium">WhatsApp</span>
        {whatsappUrl && (
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener"
            class="text-xs text-emerald-700 hover:underline font-medium inline-flex items-center gap-1"
          >
            Abrir WhatsApp ↗
          </a>
        )}
      </div>
      <input
        type="tel"
        name="customer_whatsapp"
        maxlength={CUSTOMER_WHATSAPP_MAX}
        value={values.customer_whatsapp ?? ""}
        placeholder="+54 9 381 ..."
        data-customer-whatsapp
        class={fieldClass + " font-mono text-sm"}
      />
      {errorMsg("customer_whatsapp") && (
        <p class="text-xs text-red-600 mt-1">{errorMsg("customer_whatsapp")}</p>
      )}
    </label>
  </section>

  {/* ─── Sección 3: Impresión ─── */}
  <section class={sectionClass}>
    <h2 class="font-display text-lg border-b-2 border-brand/20 pb-2">Impresión</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <label class="block">
        <span class="text-sm font-medium">Material *</span>
        <select name="material" required class={fieldClass}>
          <option value="">— Elegí —</option>
          {MATERIAL_VALUES.map((m) => (
            <option value={m} selected={values.material === m}>
              {MATERIAL_LABELS[m]}
            </option>
          ))}
        </select>
        {errorMsg("material") && (
          <p class="text-xs text-red-600 mt-1">{errorMsg("material")}</p>
        )}
      </label>

      <label class="block">
        <span class="text-sm font-medium">Color *</span>
        <div class="flex items-center gap-2 mt-1">
          <select
            name="color"
            required
            data-color-select
            class={fieldClass + " mt-0 flex-1"}
          >
            <option value="">— Elegí —</option>
            {COLOR_VALUES.map((c) => (
              <option value={c} selected={values.color === c}>
                {COLOR_LABELS[c]}
              </option>
            ))}
          </select>
          <span
            data-color-swatch
            class="inline-block w-9 h-9 rounded border-2 border-brand/30 shrink-0"
            style={
              values.color
                ? COLOR_HEX[values.color].startsWith("linear")
                  ? `background: ${COLOR_HEX[values.color]}`
                  : `background-color: ${COLOR_HEX[values.color]}`
                : "background: repeating-conic-gradient(#e5e7eb 0 25%, transparent 0 50%) 50% / 12px 12px"
            }
            aria-hidden="true"
          ></span>
        </div>
        {errorMsg("color") && (
          <p class="text-xs text-red-600 mt-1">{errorMsg("color")}</p>
        )}
      </label>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <label class="block">
        <span class="text-sm font-medium">Precio unitario (ARS) *</span>
        <input
          type="number"
          name="unit_price"
          required
          min="0"
          step="0.01"
          value={values.unit_price ?? 0}
          data-unit-price
          class={fieldClass}
        />
        {errorMsg("unit_price") && (
          <p class="text-xs text-red-600 mt-1">{errorMsg("unit_price")}</p>
        )}
      </label>

      <label class="block">
        <span class="text-sm font-medium">Unidades pedidas *</span>
        <input
          type="number"
          name="units_ordered"
          required
          min="1"
          step="1"
          value={values.units_ordered ?? 1}
          data-units-ordered
          class={fieldClass}
        />
        {errorMsg("units_ordered") && (
          <p class="text-xs text-red-600 mt-1">{errorMsg("units_ordered")}</p>
        )}
      </label>

      <label class="block">
        <span class="text-sm font-medium">Unidades hechas</span>
        <input
          type="number"
          name="units_done"
          min="0"
          step="1"
          value={values.units_done ?? 0}
          data-units-done
          class={fieldClass}
        />
        <p class="text-xs text-gray-500 mt-1">
          <span data-progress-helper>—</span>
        </p>
        {errorMsg("units_done") && (
          <p class="text-xs text-red-600 mt-1">{errorMsg("units_done")}</p>
        )}
      </label>
    </div>

    <p class="text-xs text-gray-500">
      Total estimado: <span class="font-mono font-medium" data-total-display>$0</span>
      <span class="text-gray-400">— se calcula como precio unitario × unidades pedidas.</span>
    </p>
  </section>

  {/* ─── Sección 4: Fechas + Estado + Notas ─── */}
  <section class={sectionClass}>
    <h2 class="font-display text-lg border-b-2 border-brand/20 pb-2">Fechas y estado</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <label class="block">
        <span class="text-sm font-medium">Fecha del pedido</span>
        <input
          type="datetime-local"
          name="order_date"
          value={orderDateValue}
          class={fieldClass}
        />
        <p class="text-xs text-gray-500 mt-1">
          Si lo dejás vacío al crear, se usa el momento actual.
        </p>
        {errorMsg("order_date") && (
          <p class="text-xs text-red-600 mt-1">{errorMsg("order_date")}</p>
        )}
      </label>

      <label class="block">
        <span class="text-sm font-medium">Fecha de entrega</span>
        <input
          type="date"
          name="delivery_date"
          value={deliveryDateValue}
          class={fieldClass}
        />
        {errorMsg("delivery_date") && (
          <p class="text-xs text-red-600 mt-1">{errorMsg("delivery_date")}</p>
        )}
      </label>
    </div>

    <div>
      <span class="text-sm font-medium block mb-2">Estado</span>
      <div class="flex gap-2 flex-wrap">
        {ORDER_STATUS_VALUES.map((s) => (
          <label class="cursor-pointer">
            <input
              type="radio"
              name="status"
              value={s}
              checked={(values.status ?? "pending") === s}
              class="sr-only peer"
            />
            <span
              class={`inline-block px-3 py-2 border-2 rounded-md text-sm font-medium transition-colors border-brand/30 text-brand peer-checked:bg-brand peer-checked:text-white peer-checked:border-brand hover:border-brand`}
            >
              {ORDER_STATUS_LABELS[s]}
            </span>
          </label>
        ))}
      </div>
      {errorMsg("status") && (
        <p class="text-xs text-red-600 mt-1">{errorMsg("status")}</p>
      )}
    </div>

    {/* Pago */}
    <div>
      <label class="block">
        <span class="text-sm font-medium">Pagado (ARS)</span>
        <div class="mt-1 flex items-center gap-2 flex-wrap">
          <input
            type="number"
            name="paid_amount"
            min="0"
            step="0.01"
            value={values.paid_amount ?? 0}
            data-paid-amount
            class={fieldClass + " mt-0 flex-1 min-w-[160px] font-mono"}
          />
          <button
            type="button"
            data-paid-full
            class="px-3 py-2 border-2 border-emerald-600 text-emerald-700 rounded-md text-xs font-medium hover:bg-emerald-600 hover:text-white transition-colors whitespace-nowrap"
          >
            Pagado total
          </button>
          <button
            type="button"
            data-paid-clear
            class="px-3 py-2 border-2 border-gray-400 text-gray-600 rounded-md text-xs font-medium hover:bg-gray-500 hover:text-white transition-colors whitespace-nowrap"
          >
            Limpiar
          </button>
        </div>
        <p class="text-xs text-gray-500 mt-1">
          <span data-paid-helper>—</span>
        </p>
        {errorMsg("paid_amount") && (
          <p class="text-xs text-red-600 mt-1">{errorMsg("paid_amount")}</p>
        )}
      </label>
    </div>

    <label class="block">
      <span class="text-sm font-medium">Notas</span>
      <textarea
        name="notes"
        rows="3"
        maxlength={NOTES_MAX}
        class={fieldClass}
        placeholder="Detalles del pedido, indicaciones, etc."
      >{values.notes ?? ""}</textarea>
      {errorMsg("notes") && (
        <p class="text-xs text-red-600 mt-1">{errorMsg("notes")}</p>
      )}
    </label>
  </section>

  {/* ─── Footer ─── */}
  <div class="flex flex-wrap items-center justify-between gap-3">
    <a
      href="/admin/pedidos"
      class="text-sm text-gray-600 hover:text-brand underline-offset-4 hover:underline"
    >
      ← Volver al listado
    </a>

    <div class="flex items-center gap-3">
      {mode === "edit" && orderId && (
        <button
          type="submit"
          name="action"
          value="delete"
          formnovalidate
          data-confirm="¿Seguro que querés borrar este pedido? Esta acción no se puede deshacer."
          class="px-4 py-2 border-2 border-red-600 text-red-600 rounded-md hover:bg-red-600 hover:text-white transition-colors text-sm font-medium"
        >
          Eliminar
        </button>
      )}
      <button
        type="submit"
        name="action"
        value="save"
        class="px-5 py-2.5 bg-accent text-white rounded-md hover:bg-accent-hover transition-colors font-medium"
      >
        {mode === "create" ? "Crear pedido" : "Guardar cambios"}
      </button>
    </div>
  </div>
</form>

<script>
  // ─── Color swatch update ───
  // Hex map duplicado client-side (el componente Astro renderiza server-side
  // así que necesitamos esto para reaccionar a cambios del select).
  const COLOR_HEX_MAP: Record<string, string> = {
    blanco: "#ffffff",
    negro: "#1a1a1a",
    gris: "#9ca3af",
    azul: "#2563eb",
    rojo: "#dc2626",
    verde: "#16a34a",
    amarillo: "#facc15",
    naranja: "#f97316",
    morado: "#9333ea",
    transparente: "linear-gradient(45deg,#fff 0%,#f3f4f6 50%,#fff 100%)",
    celeste: "#7dd3fc",
  };

  const colorSelect = document.querySelector<HTMLSelectElement>("[data-color-select]");
  const colorSwatch = document.querySelector<HTMLElement>("[data-color-swatch]");
  colorSelect?.addEventListener("change", () => {
    if (!colorSwatch) return;
    const v = colorSelect.value;
    if (!v) {
      colorSwatch.style.background =
        "repeating-conic-gradient(#e5e7eb 0 25%, transparent 0 50%) 50% / 12px 12px";
      return;
    }
    const swatch = COLOR_HEX_MAP[v] ?? "#9ca3af";
    if (swatch.startsWith("linear")) {
      colorSwatch.style.background = swatch;
    } else {
      colorSwatch.style.background = swatch;
    }
  });

  // ─── Total + progress helper update ───
  const unitPriceEl = document.querySelector<HTMLInputElement>("[data-unit-price]");
  const unitsOrderedEl = document.querySelector<HTMLInputElement>("[data-units-ordered]");
  const unitsDoneEl = document.querySelector<HTMLInputElement>("[data-units-done]");
  const totalEl = document.querySelector<HTMLElement>("[data-total-display]");
  const progressHelperEl = document.querySelector<HTMLElement>("[data-progress-helper]");
  const paidAmountEl = document.querySelector<HTMLInputElement>("[data-paid-amount]");
  const paidHelperEl = document.querySelector<HTMLElement>("[data-paid-helper]");
  const paidFullBtn = document.querySelector<HTMLButtonElement>("[data-paid-full]");
  const paidClearBtn = document.querySelector<HTMLButtonElement>("[data-paid-clear]");

  function fmtArs(n: number): string {
    return "$" + Math.round(n).toLocaleString("es-AR");
  }

  function currentTotal(): number {
    const price = Number(unitPriceEl?.value ?? "0") || 0;
    const ordered = Number(unitsOrderedEl?.value ?? "0") || 0;
    return price * ordered;
  }

  function updatePaidHelper() {
    if (!paidHelperEl) return;
    const total = currentTotal();
    const paid = Number(paidAmountEl?.value ?? "0") || 0;
    const balance = Math.max(0, total - paid);
    if (total <= 0) {
      paidHelperEl.textContent = "—";
      paidHelperEl.className = "";
      return;
    }
    if (balance <= 0.01) {
      paidHelperEl.innerHTML = `<span class="text-emerald-700 font-medium">✓ Pagado completo</span> (${fmtArs(paid)} de ${fmtArs(total)})`;
    } else if (paid > 0) {
      paidHelperEl.innerHTML = `${fmtArs(paid)} de ${fmtArs(total)} · <span class="text-amber-700 font-medium">Saldo: ${fmtArs(balance)}</span>`;
    } else {
      paidHelperEl.innerHTML = `Total: ${fmtArs(total)} · <span class="text-amber-700 font-medium">Saldo: ${fmtArs(balance)}</span>`;
    }
  }

  function updateTotals() {
    const ordered = Number(unitsOrderedEl?.value ?? "0") || 0;
    const done = Number(unitsDoneEl?.value ?? "0") || 0;
    if (totalEl) totalEl.textContent = fmtArs(currentTotal());

    if (progressHelperEl) {
      if (ordered <= 0) {
        progressHelperEl.textContent = "—";
      } else {
        const pct = Math.min(100, Math.max(0, Math.round((done / ordered) * 100)));
        progressHelperEl.textContent = `${done} de ${ordered} (${pct}%)`;
      }
    }
    updatePaidHelper();
  }

  unitPriceEl?.addEventListener("input", updateTotals);
  unitsOrderedEl?.addEventListener("input", updateTotals);
  unitsDoneEl?.addEventListener("input", updateTotals);
  paidAmountEl?.addEventListener("input", updatePaidHelper);

  paidFullBtn?.addEventListener("click", () => {
    if (!paidAmountEl) return;
    const total = currentTotal();
    paidAmountEl.value = total > 0 ? String(total) : "0";
    updatePaidHelper();
  });
  paidClearBtn?.addEventListener("click", () => {
    if (!paidAmountEl) return;
    paidAmountEl.value = "0";
    updatePaidHelper();
  });

  updateTotals();

  // ─── Autocomplete cliente: datalist → autollena WhatsApp ───
  const customerNameEl = document.querySelector<HTMLInputElement>("[data-customer-name]");
  const customerWaEl = document.querySelector<HTMLInputElement>("[data-customer-whatsapp]");
  const datalistEl = document.getElementById("client-autocomplete-list") as HTMLDataListElement | null;

  function autofillWhatsAppFromName() {
    if (!customerNameEl || !customerWaEl || !datalistEl) return;
    const typed = customerNameEl.value.trim();
    if (!typed) return;
    // Buscar option con value === typed exacto
    const opts = datalistEl.querySelectorAll<HTMLOptionElement>("option");
    for (const opt of opts) {
      if (opt.value === typed) {
        const wa = opt.getAttribute("data-whatsapp") ?? "";
        // Solo autollenar si el campo de WhatsApp esta vacio — no pisar lo que el usuario tipeo a mano
        if (wa && !customerWaEl.value.trim()) {
          customerWaEl.value = wa;
        }
        break;
      }
    }
  }

  customerNameEl?.addEventListener("change", autofillWhatsAppFromName);
  customerNameEl?.addEventListener("blur", autofillWhatsAppFromName);

  // Confirm dialogs handled globally in AdminLayout
</script>
