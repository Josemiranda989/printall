---
import {
  SUPPLY_SALE_STATUS_LABELS,
  SUPPLY_SALE_STATUS_VALUES,
  type MaterialPrice,
} from "../../lib/types";
import {
  SUPPLY_SALE_NOTES_MAX,
  type SupplySaleFormData,
} from "../../lib/admin-supply-sales";
import type { ClientForAutocomplete } from "../../lib/admin-clients";

export interface Props {
  values: Partial<SupplySaleFormData>;
  errors?: Record<string, string>;
  mode: "create" | "edit";
  saleId?: string;
  materials: MaterialPrice[];
  clients?: ClientForAutocomplete[];
}

const { values, errors = {}, mode, saleId, materials, clients = [] } = Astro.props;

const fieldClass =
  "mt-1 block w-full border-2 border-brand rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-accent disabled:bg-gray-100";

function errorMsg(field: string) {
  return errors[field];
}

const currentStatus = values.status ?? "reservado";
---

<form method="POST" class="space-y-5">
  {errors._global && (
    <div class="border-2 border-red-500 bg-red-50 text-red-800 px-3 py-2 rounded-md text-sm">
      {errors._global}
    </div>
  )}

  <div class="bg-white border-2 border-brand rounded-lg p-5 space-y-5 shadow-[4px_4px_0_var(--color-brand)]">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <label class="block">
        <span class="text-sm font-medium">Cliente *</span>
        <input
          type="text"
          name="customer_name"
          required
          maxlength={120}
          value={values.customer_name ?? ""}
          placeholder="Nombre del cliente"
          list="client-autocomplete-list"
          autocomplete="off"
          data-customer-name
          class={fieldClass}
        />
        {clients.length > 0 && (
          <datalist id="client-autocomplete-list">
            {clients.map((c) => (
              <option value={c.name} data-whatsapp={c.whatsapp}>
                {c.whatsapp ? `${c.name} · ${c.whatsapp}` : c.name}
              </option>
            ))}
          </datalist>
        )}
        {errorMsg("customer_name") && (
          <p class="text-xs text-red-600 mt-1">{errorMsg("customer_name")}</p>
        )}
      </label>

      <label class="block">
        <span class="text-sm font-medium">WhatsApp</span>
        <input
          type="text"
          name="customer_whatsapp"
          maxlength={30}
          value={values.customer_whatsapp ?? ""}
          placeholder="Ej: 3815551234"
          data-customer-whatsapp
          class={fieldClass}
        />
      </label>
    </div>

    <label class="block">
      <span class="text-sm font-medium">Insumo *</span>
      <select name="item" required data-item-select class={fieldClass}>
        <option value="" disabled selected={!values.item}>
          — Elegí un insumo —
        </option>
        {materials.map((m) => (
          <option
            value={m.id}
            selected={values.item === m.id}
            data-sell-price={m.sell_price}
            data-colors={m.colors || ""}
          >
            {m.name}
          </option>
        ))}
      </select>
      <p class="text-xs text-gray-500 mt-1">
        Al elegir un insumo se autocompleta el precio unitario con su precio de
        venta. Podés editarlo — queda fijado al momento de la venta.
      </p>
      {errorMsg("item") && (
        <p class="text-xs text-red-600 mt-1">{errorMsg("item")}</p>
      )}
    </label>

    <label class="block" id="color-field" class:list={["hidden", !values.color]}>
      <span class="text-sm font-medium">Color</span>
      <input
        type="text"
        name="color"
        maxlength={100}
        value={values.color ?? ""}
        placeholder="Ej: blanco, negro"
        data-color-input
        class={fieldClass}
      />
      <p class="text-xs text-gray-500 mt-1">
        Solo si el insumo tiene variantes de color.
      </p>
    </label>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <label class="block">
        <span class="text-sm font-medium">Cantidad *</span>
        <input
          type="number"
          name="quantity"
          required
          min="1"
          step="1"
          value={values.quantity ?? 1}
          data-quantity
          class={fieldClass}
        />
        {errorMsg("quantity") && (
          <p class="text-xs text-red-600 mt-1">{errorMsg("quantity")}</p>
        )}
      </label>

      <label class="block">
        <span class="text-sm font-medium">Precio unitario *</span>
        <input
          type="number"
          name="unit_price"
          required
          min="0"
          step="0.01"
          value={values.unit_price ?? 0}
          data-unit-price
          class={fieldClass}
        />
        {errorMsg("unit_price") && (
          <p class="text-xs text-red-600 mt-1">{errorMsg("unit_price")}</p>
        )}
      </label>

      <div class="block">
        <span class="text-sm font-medium">Total</span>
        <div
          class="mt-1 px-3 py-2 border-2 border-brand/30 rounded-md bg-surface font-mono font-medium"
          data-total-display
        >
          —
        </div>
      </div>
    </div>

    <div>
      <span class="text-sm font-medium block mb-2">Estado *</span>
      <div class="flex gap-2 flex-wrap">
        {SUPPLY_SALE_STATUS_VALUES.map((s) => (
          <label class="cursor-pointer">
            <input
              type="radio"
              name="status"
              value={s}
              checked={currentStatus === s}
              class="sr-only peer"
            />
            <span class="inline-block px-4 py-2 border-2 rounded-md text-sm font-medium transition-colors border-brand/30 text-brand peer-checked:bg-brand peer-checked:text-white peer-checked:border-brand hover:border-brand">
              {SUPPLY_SALE_STATUS_LABELS[s]}
            </span>
          </label>
        ))}
      </div>
      <p class="text-xs text-gray-500 mt-1">
        El estado de entrega es independiente del pago.
      </p>
      {errorMsg("status") && (
        <p class="text-xs text-red-600 mt-1">{errorMsg("status")}</p>
      )}
    </div>

    <label class="inline-flex items-center gap-2 cursor-pointer">
      <input
        type="checkbox"
        name="is_paid"
        checked={values.is_paid ?? false}
        class="w-4 h-4 accent-accent"
      />
      <span class="text-sm font-medium">Pagado</span>
    </label>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <label class="block">
        <span class="text-sm font-medium">Fecha de venta *</span>
        <input
          type="date"
          name="sale_date"
          required
          value={values.sale_date ?? ""}
          class={fieldClass}
        />
        {errorMsg("sale_date") && (
          <p class="text-xs text-red-600 mt-1">{errorMsg("sale_date")}</p>
        )}
      </label>

      <label class="block">
        <span class="text-sm font-medium">Fecha de entrega</span>
        <input
          type="date"
          name="delivery_date"
          value={values.delivery_date ?? ""}
          class={fieldClass}
        />
      </label>
    </div>

    <label class="block">
      <span class="text-sm font-medium">Notas</span>
      <textarea
        name="notes"
        maxlength={SUPPLY_SALE_NOTES_MAX}
        rows="3"
        placeholder="Observaciones de la venta"
        class={fieldClass}>{values.notes ?? ""}</textarea>
      {errorMsg("notes") && (
        <p class="text-xs text-red-600 mt-1">{errorMsg("notes")}</p>
      )}
    </label>
  </div>

  <div class="flex flex-wrap items-center justify-between gap-3">
    <a
      href="/admin/insumos"
      class="text-sm text-gray-600 hover:text-brand underline-offset-4 hover:underline"
    >
      ← Volver al listado
    </a>

    <div class="flex items-center gap-3">
      {mode === "edit" && saleId && (
        <button
          type="submit"
          name="action"
          value="delete"
          formnovalidate
          data-confirm="¿Seguro que querés borrar esta venta? Esta acción no se puede deshacer."
          class="px-4 py-2 border-2 border-red-600 text-red-600 rounded-md hover:bg-red-600 hover:text-white transition-colors text-sm font-medium"
        >
          Eliminar
        </button>
      )}
      <button
        type="submit"
        name="action"
        value="save"
        class="px-5 py-2.5 bg-accent text-white rounded-md hover:bg-accent-hover transition-colors font-medium"
      >
        {mode === "create" ? "Registrar venta" : "Guardar cambios"}
      </button>
    </div>
  </div>
</form>

<script>
  // Auto-fill unit price from selected material
  const itemSelect = document.querySelector<HTMLSelectElement>("[data-item-select]");
  const priceInput = document.querySelector<HTMLInputElement>("[data-unit-price]");
  const totalDisplay = document.querySelector<HTMLElement>("[data-total-display]");
  const quantityInput = document.querySelector<HTMLInputElement>("[data-quantity]");
  const colorField = document.getElementById("color-field");
  const colorInput = document.querySelector<HTMLInputElement>("[data-color-input]");
  
  function updateTotal() {
    if (!totalDisplay) return;
    const qty = Number(quantityInput?.value) || 0;
    const price = Number(priceInput?.value) || 0;
    totalDisplay.textContent = "$" + (qty * price).toLocaleString("es-AR");
  }
  
  quantityInput?.addEventListener("input", updateTotal);
  priceInput?.addEventListener("input", updateTotal);
  
  itemSelect?.addEventListener("change", () => {
    const option = itemSelect.selectedOptions[0];
    if (option) {
      const sellPrice = option.dataset.sellPrice;
      if (sellPrice && priceInput) {
        priceInput.value = sellPrice;
      }
      // Show/hide color field
      const colors = option.dataset.colors || "";
      if (colorField) {
        colorField.classList.toggle("hidden", !colors);
        if (!colors && colorInput) colorInput.value = "";
      }
    }
    updateTotal();
  });
  
  // Initial state: show color field if material already has colors
  if (itemSelect && colorField) {
    const selected = itemSelect.selectedOptions[0];
    const colors = selected?.dataset.colors || "";
    colorField.classList.toggle("hidden", !colors);
  }
  
  updateTotal();

  // ─── Autocomplete cliente: datalist → autollena WhatsApp ───
  const customerNameEl = document.querySelector<HTMLInputElement>("[data-customer-name]");
  const customerWaEl = document.querySelector<HTMLInputElement>("[data-customer-whatsapp]");
  const datalistEl = document.getElementById("client-autocomplete-list") as HTMLDataListElement | null;

  function autofillWhatsAppFromName() {
    if (!customerNameEl || !customerWaEl || !datalistEl) return;
    const typed = customerNameEl.value.trim();
    if (!typed) return;
    const opts = datalistEl.querySelectorAll<HTMLOptionElement>("option");
    for (const opt of opts) {
      if (opt.value === typed) {
        const wa = opt.getAttribute("data-whatsapp") ?? "";
        if (wa && !customerWaEl.value.trim()) {
          customerWaEl.value = wa;
        }
        break;
      }
    }
  }

  customerNameEl?.addEventListener("change", autofillWhatsAppFromName);
  customerNameEl?.addEventListener("blur", autofillWhatsAppFromName);
</script>