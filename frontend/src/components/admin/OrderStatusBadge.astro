---
import type { OrderStatus } from "../../lib/types";
import { ORDER_STATUS_COLORS, ORDER_STATUS_LABELS } from "../../lib/types";

export interface Props {
  status: OrderStatus;
  size?: "sm" | "md";
}

const { status, size = "sm" } = Astro.props;
const sizeClass = size === "md" ? "text-sm px-2.5 py-1" : "text-xs px-2 py-0.5";
---

<span
  class={`inline-block ${sizeClass} rounded border font-medium ${ORDER_STATUS_COLORS[status]}`}
>
  {ORDER_STATUS_LABELS[status]}
</span>
