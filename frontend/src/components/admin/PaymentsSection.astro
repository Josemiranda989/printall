---
import {
  PAYMENT_METHOD_LABELS,
  PAYMENT_METHOD_VALUES,
  type Payment,
} from "../../lib/admin-payments";

export interface Props {
  targetType: "order" | "sale";
  targetId: string;
  payments: Payment[];
  total: number;
  /** Si openByDefault=true, el details abre al renderizar. */
  openByDefault?: boolean;
}

const {
  targetType,
  targetId,
  payments,
  total,
  openByDefault = false,
} = Astro.props;

const today = new Date().toISOString().slice(0, 10);
const sumPaid = payments.reduce((acc, p) => acc + (p.amount ?? 0), 0);
const saldo = Math.max(0, total - sumPaid);

function fmtMoney(n: number): string {
  return "$" + Math.round(n).toLocaleString("es-AR");
}
function fmtDate(iso: string): string {
  if (!iso) return "—";
  return iso.slice(0, 10);
}
---

<details
  class="bg-white border-2 border-blue-500 rounded-lg shadow-[4px_4px_0_var(--color-brand)] overflow-hidden"
  open={openByDefault}
>
  <summary class="cursor-pointer px-4 py-3 font-medium text-sm sm:text-base hover:bg-blue-50 select-none flex items-center gap-2 flex-wrap">
    <span class="text-blue-600">💵</span>
    <span>Pagos detallados</span>
    <span class="text-xs font-mono bg-blue-100 text-blue-700 px-2 py-0.5 rounded-full">
      {payments.length}
    </span>
    <span class="ml-auto text-xs font-mono text-gray-600">
      {fmtMoney(sumPaid)} / {fmtMoney(total)}
      {saldo > 0 && (
        <span class="text-amber-700 ml-1">· saldo {fmtMoney(saldo)}</span>
      )}
    </span>
  </summary>

  <div class="border-t-2 border-blue-300 p-4 sm:p-5 space-y-4">
    {payments.length === 0 ? (
      <p class="text-sm text-gray-600">
        Este registro todavía no tiene pagos individuales cargados.
      </p>
    ) : (
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-surface border-b border-blue-200">
            <tr>
              <th class="text-left px-2 py-2 font-medium">Fecha</th>
              <th class="text-left px-2 py-2 font-medium">Método</th>
              <th class="text-right px-2 py-2 font-medium">Monto</th>
              <th class="text-left px-2 py-2 font-medium hidden sm:table-cell">Notas</th>
              <th class="text-right px-2 py-2 font-medium">Acción</th>
            </tr>
          </thead>
          <tbody>
            {payments.map((p) => (
              <tr class="border-b border-blue-100 last:border-b-0">
                <td class="px-2 py-2 font-mono text-xs whitespace-nowrap">
                  {fmtDate(p.paid_at)}
                </td>
                <td class="px-2 py-2">
                  <span class="text-xs px-2 py-0.5 rounded bg-blue-100 text-blue-800 whitespace-nowrap">
                    {PAYMENT_METHOD_LABELS[p.method]}
                  </span>
                </td>
                <td class="px-2 py-2 text-right font-mono font-medium whitespace-nowrap">
                  {fmtMoney(p.amount)}
                </td>
                <td class="px-2 py-2 text-gray-600 text-xs hidden sm:table-cell break-words">
                  {p.notes || "—"}
                </td>
                <td class="px-2 py-2 text-right">
                  <button
                    type="button"
                    data-delete-payment
                    data-id={p.id}
                    class="text-xs text-red-600 hover:text-red-800 hover:underline whitespace-nowrap"
                    title="Eliminar pago"
                  >
                    Borrar
                  </button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}

    {/* ─── Formulario inline para agregar un pago ─── */}
    <form
      class="bg-blue-50 border-2 border-blue-300 rounded-md p-3 sm:p-4 space-y-3"
      data-payment-form
      data-target-type={targetType}
      data-target-id={targetId}
    >
      <p class="text-xs font-semibold text-blue-900 uppercase tracking-wide">
        Registrar un nuevo pago
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
        <label class="block">
          <span class="text-xs font-medium text-gray-700">Fecha *</span>
          <input
            type="date"
            name="paid_at"
            required
            value={today}
            class="mt-0.5 block w-full border-2 border-blue-300 rounded-md px-2 py-1.5 text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
          />
        </label>

        <label class="block">
          <span class="text-xs font-medium text-gray-700">Monto (ARS) *</span>
          <input
            type="number"
            name="amount"
            required
            min="0.01"
            step="0.01"
            placeholder="0"
            class="mt-0.5 block w-full border-2 border-blue-300 rounded-md px-2 py-1.5 text-sm font-mono focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
          />
        </label>

        <label class="block">
          <span class="text-xs font-medium text-gray-700">Método *</span>
          <select
            name="method"
            required
            class="mt-0.5 block w-full border-2 border-blue-300 rounded-md px-2 py-1.5 text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
          >
            {PAYMENT_METHOD_VALUES.map((v) => (
              <option value={v}>{PAYMENT_METHOD_LABELS[v]}</option>
            ))}
          </select>
        </label>
      </div>

      <label class="block">
        <span class="text-xs font-medium text-gray-700">Notas (opcional)</span>
        <input
          type="text"
          name="notes"
          maxlength="500"
          placeholder="Comprobante, referencia, etc."
          class="mt-0.5 block w-full border-2 border-blue-300 rounded-md px-2 py-1.5 text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
        />
      </label>

      <div class="flex items-center justify-between gap-2 flex-wrap">
        <p class="text-xs text-blue-700">
          Al guardar, se recalcula el saldo automáticamente.
        </p>
        <div class="flex gap-2">
          {saldo > 0 && (
            <button
              type="button"
              data-fill-saldo
              data-amount={saldo}
              class="px-3 py-1.5 border-2 border-blue-500 text-blue-700 rounded-md text-xs font-medium hover:bg-blue-100 transition-colors whitespace-nowrap"
            >
              Llenar saldo ({fmtMoney(saldo)})
            </button>
          )}
          <button
            type="submit"
            class="px-4 py-1.5 bg-blue-600 text-white rounded-md text-sm font-medium hover:bg-blue-700 transition-colors whitespace-nowrap"
          >
            Registrar pago
          </button>
        </div>
      </div>
    </form>
  </div>
</details>

<script>
  // ─── Submit del form ───
  document.querySelectorAll<HTMLFormElement>("[data-payment-form]").forEach((form) => {
    form.addEventListener("submit", async (ev) => {
      ev.preventDefault();
      const targetType = form.dataset.targetType ?? "";
      const targetId = form.dataset.targetId ?? "";
      const fd = new FormData(form);
      const amount = Number(fd.get("amount"));
      const paid_at = String(fd.get("paid_at") ?? "");
      const method = String(fd.get("method") ?? "");
      const notes = String(fd.get("notes") ?? "");

      if (!amount || amount <= 0) {
        (window as any).__showToast?.({ type: "error", message: "El monto debe ser mayor a 0." });
        return;
      }

      const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      if (btn) btn.disabled = true;

      try {
        const res = await fetch("/admin/api/payments", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ target_type: targetType, target_id: targetId, amount, method, paid_at, notes }),
        });
        const data = (await res.json()) as { ok: boolean; error?: string };
        if (!res.ok || !data.ok) {
          (window as any).__showToast?.({ type: "error", message: data.error || "No se pudo registrar el pago." });
          return;
        }
        (window as any).__showToast?.({ type: "success", message: "Pago registrado." });
        // Reload para que se vea el saldo recalculado y la lista actualizada
        setTimeout(() => window.location.reload(), 400);
      } catch {
        (window as any).__showToast?.({ type: "error", message: "Error de red al registrar el pago." });
      } finally {
        if (btn) btn.disabled = false;
      }
    });
  });

  // ─── "Llenar saldo" ───
  document.querySelectorAll<HTMLButtonElement>("[data-fill-saldo]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const amount = btn.dataset.amount ?? "0";
      const form = btn.closest("form");
      const input = form?.querySelector<HTMLInputElement>('input[name="amount"]');
      if (input) {
        input.value = amount;
        input.focus();
      }
    });
  });

  // ─── Borrar pago ───
  document.querySelectorAll<HTMLButtonElement>("[data-delete-payment]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const id = btn.dataset.id ?? "";
      if (!id) return;
      if (!confirm("¿Borrar este pago? Se recalcula el saldo.")) return;

      btn.disabled = true;
      try {
        const res = await fetch(`/admin/api/payments/${id}`, { method: "DELETE" });
        const data = (await res.json()) as { ok: boolean; error?: string };
        if (!res.ok || !data.ok) {
          (window as any).__showToast?.({ type: "error", message: data.error || "No se pudo borrar el pago." });
          btn.disabled = false;
          return;
        }
        (window as any).__showToast?.({ type: "success", message: "Pago eliminado." });
        setTimeout(() => window.location.reload(), 400);
      } catch {
        (window as any).__showToast?.({ type: "error", message: "Error de red." });
        btn.disabled = false;
      }
    });
  });
</script>
