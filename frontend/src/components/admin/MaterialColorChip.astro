---
import type { Color, Material } from "../../lib/types";
import { COLOR_HEX, COLOR_LABELS, MATERIAL_LABELS } from "../../lib/types";

export interface Props {
  material: Material;
  color: Color;
  /** Si true, oculta el label textual y solo muestra el chip de color (compacto). */
  compact?: boolean;
}

const { material, color, compact = false } = Astro.props;
const swatch = COLOR_HEX[color];
const isGradient = swatch.startsWith("linear-gradient");
const swatchStyle = isGradient ? `background: ${swatch}` : `background-color: ${swatch}`;
const needsBorder = color === "blanco" || color === "transparente";
const borderClass = needsBorder ? "border border-gray-300" : "border border-black/10";
---

<span
  class="inline-flex items-center gap-1.5"
  title={`${MATERIAL_LABELS[material]} ${COLOR_LABELS[color]}`}
>
  <span
    class={`inline-block w-3 h-3 rounded-full shrink-0 ${borderClass}`}
    style={swatchStyle}
    aria-hidden="true"
  ></span>
  {!compact && (
    <span class="text-xs font-mono text-gray-700">
      {MATERIAL_LABELS[material]}
    </span>
  )}
</span>
