---
import {
  QUOTE_DESCRIPTION_MAX,
  QUOTE_NOTES_MAX,
  QUOTE_STATUS_LABELS,
  QUOTE_STATUS_VALUES,
  QUOTE_TITLE_MAX,
  type QuoteFormData,
} from "../../lib/admin-quotes";

export interface Props {
  values: Partial<QuoteFormData>;
  errors?: Record<string, string>;
  mode: "create" | "edit";
  quoteId?: string;
  convertedOrderId?: string;
}

const { values, errors = {}, mode, quoteId, convertedOrderId } = Astro.props;

const fieldClass =
  "mt-1 block w-full border-2 border-brand rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-accent disabled:bg-gray-100";
const sectionClass =
  "bg-white border-2 border-brand rounded-lg p-5 space-y-5 shadow-[4px_4px_0_var(--color-brand)]";

function errorMsg(field: string) {
  return errors[field];
}

const isConverted = values.status === "converted";
---

<form method="POST" class="space-y-5">
  {errors._global && (
    <div class="border-2 border-red-500 bg-red-50 text-red-800 px-3 py-2 rounded-md text-sm">
      {errors._global}
    </div>
  )}

  {isConverted && convertedOrderId && (
    <div class="border-2 border-emerald-500 bg-emerald-50 text-emerald-800 px-3 py-3 rounded-md text-sm flex items-center justify-between gap-2 flex-wrap">
      <span>✓ Esta cotización ya fue convertida en pedido.</span>
      <a
        href={`/admin/pedidos/${convertedOrderId}`}
        class="text-emerald-700 hover:underline font-medium"
      >
        Ver pedido →
      </a>
    </div>
  )}

  <section class={sectionClass}>
    <h2 class="font-display text-lg border-b-2 border-brand/20 pb-2">Cliente</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <label class="block">
        <span class="text-sm font-medium">Nombre *</span>
        <input
          type="text"
          name="customer_name"
          required
          maxlength="120"
          value={values.customer_name ?? ""}
          class={fieldClass}
        />
        {errorMsg("customer_name") && (
          <p class="text-xs text-red-600 mt-1">{errorMsg("customer_name")}</p>
        )}
      </label>

      <label class="block">
        <span class="text-sm font-medium">WhatsApp</span>
        <input
          type="tel"
          name="customer_whatsapp"
          maxlength="30"
          value={values.customer_whatsapp ?? ""}
          placeholder="+54 9 381 ..."
          class={fieldClass + " font-mono text-sm"}
        />
      </label>
    </div>
  </section>

  <section class={sectionClass}>
    <h2 class="font-display text-lg border-b-2 border-brand/20 pb-2">Cotización</h2>

    <label class="block">
      <span class="text-sm font-medium">Título *</span>
      <input
        type="text"
        name="title"
        required
        maxlength={QUOTE_TITLE_MAX}
        value={values.title ?? ""}
        placeholder="Ej: Soporte vertical para celular"
        class={fieldClass}
      />
      {errorMsg("title") && (
        <p class="text-xs text-red-600 mt-1">{errorMsg("title")}</p>
      )}
    </label>

    <label class="block">
      <span class="text-sm font-medium">Descripción / Especificaciones</span>
      <textarea
        name="description"
        rows="3"
        maxlength={QUOTE_DESCRIPTION_MAX}
        class={fieldClass}
        placeholder="Material, color, dimensiones, plazos, etc."
      >{values.description ?? ""}</textarea>
      {errorMsg("description") && (
        <p class="text-xs text-red-600 mt-1">{errorMsg("description")}</p>
      )}
    </label>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <label class="block">
        <span class="text-sm font-medium">Precio unitario (ARS) *</span>
        <input
          type="number"
          name="unit_price"
          required
          min="0"
          step="0.01"
          value={values.unit_price ?? 0}
          class={fieldClass}
        />
        {errorMsg("unit_price") && (
          <p class="text-xs text-red-600 mt-1">{errorMsg("unit_price")}</p>
        )}
      </label>

      <label class="block">
        <span class="text-sm font-medium">Cantidad *</span>
        <input
          type="number"
          name="quantity"
          required
          min="1"
          step="1"
          value={values.quantity ?? 1}
          class={fieldClass}
        />
        {errorMsg("quantity") && (
          <p class="text-xs text-red-600 mt-1">{errorMsg("quantity")}</p>
        )}
      </label>

      <label class="block">
        <span class="text-sm font-medium">Válida hasta</span>
        <input
          type="date"
          name="valid_until"
          value={values.valid_until ?? ""}
          class={fieldClass}
        />
      </label>
    </div>

    <div>
      <span class="text-sm font-medium block mb-2">Estado</span>
      <div class="flex gap-2 flex-wrap">
        {QUOTE_STATUS_VALUES.map((s) => (
          <label class="cursor-pointer">
            <input
              type="radio"
              name="status"
              value={s}
              checked={(values.status ?? "pending") === s}
              class="sr-only peer"
            />
            <span class="inline-block px-3 py-1.5 border-2 rounded-md text-sm font-medium transition-colors border-brand/30 text-brand peer-checked:bg-brand peer-checked:text-white peer-checked:border-brand hover:border-brand">
              {QUOTE_STATUS_LABELS[s]}
            </span>
          </label>
        ))}
      </div>
    </div>

    <label class="block">
      <span class="text-sm font-medium">Notas internas</span>
      <textarea
        name="notes"
        rows="2"
        maxlength={QUOTE_NOTES_MAX}
        class={fieldClass}
      >{values.notes ?? ""}</textarea>
    </label>
  </section>

  <div class="flex flex-wrap items-center justify-between gap-3">
    <a
      href="/admin/cotizaciones"
      class="text-sm text-gray-600 hover:text-brand underline-offset-4 hover:underline"
    >
      ← Volver al listado
    </a>

    <div class="flex items-center gap-3 flex-wrap">
      {mode === "edit" && quoteId && !isConverted && (
        <button
          type="button"
          data-convert-quote
          data-quote-id={quoteId}
          class="px-4 py-2 bg-emerald-600 text-white rounded-md text-sm font-medium hover:bg-emerald-700 transition-colors"
        >
          ⇨ Convertir a pedido
        </button>
      )}
      {mode === "edit" && quoteId && (
        <button
          type="submit"
          name="action"
          value="delete"
          formnovalidate
          data-confirm="¿Borrar esta cotización?"
          class="px-4 py-2 border-2 border-red-600 text-red-600 rounded-md hover:bg-red-600 hover:text-white transition-colors text-sm font-medium"
        >
          Eliminar
        </button>
      )}
      <button
        type="submit"
        name="action"
        value="save"
        class="px-5 py-2.5 bg-accent text-white rounded-md hover:bg-accent-hover transition-colors font-medium"
      >
        {mode === "create" ? "Crear cotización" : "Guardar cambios"}
      </button>
    </div>
  </div>
</form>

<script>
  document.querySelectorAll<HTMLButtonElement>("[data-convert-quote]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const id = btn.dataset.quoteId ?? "";
      if (!id) return;
      if (!confirm("¿Convertir esta cotización en un pedido? Se crea un pedido nuevo con los datos.")) return;

      btn.disabled = true;
      try {
        const res = await fetch(`/admin/api/quotes/${id}/convert`, { method: "POST" });
        const data = (await res.json()) as { ok: boolean; order_id?: string; error?: string };
        if (!res.ok || !data.ok) {
          (window as any).__showToast?.({ type: "error", message: data.error || "No se pudo convertir." });
          btn.disabled = false;
          return;
        }
        (window as any).__showToast?.({ type: "success", message: "Cotización convertida en pedido." });
        setTimeout(() => {
          window.location.href = `/admin/pedidos/${data.order_id}`;
        }, 600);
      } catch {
        (window as any).__showToast?.({ type: "error", message: "Error de red." });
        btn.disabled = false;
      }
    });
  });
</script>
