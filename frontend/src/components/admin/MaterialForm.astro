---
import {
  COLOR_HEX,
  MATERIAL_KIND_LABELS,
  MATERIAL_KIND_UNIT,
  MATERIAL_KIND_VALUES,
} from "../../lib/types";
import {
  MATERIAL_NAME_MAX,
  type MaterialFormData,
} from "../../lib/admin-materials";

export interface Props {
  values: Partial<MaterialFormData>;
  errors?: Record<string, string>;
  mode: "create" | "edit";
  materialId?: string;
}

const { values, errors = {}, mode, materialId } = Astro.props;

const fieldClass =
  "mt-1 block w-full border-2 border-brand rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-accent disabled:bg-gray-100";

function errorMsg(field: string) {
  return errors[field];
}

const currentKind = values.kind ?? "filament";

const initialColors = (values.colors ?? "")
  .split(",")
  .map((c) => c.trim().toLowerCase())
  .filter(Boolean);

function colorBg(c: string): string {
  const hex = (COLOR_HEX as Record<string, string>)[c];
  if (hex && hex.startsWith("linear")) return `background: ${hex}`;
  if (hex) return `background-color: ${hex}`;
  return "background: repeating-conic-gradient(#e5e7eb 0 25%, transparent 0 50%) 50% / 8px 8px";
}
---

<form method="POST" class="space-y-5">
  {errors._global && (
    <div class="border-2 border-red-500 bg-red-50 text-red-800 px-3 py-2 rounded-md text-sm">
      {errors._global}
    </div>
  )}

  <div class="bg-white border-2 border-brand rounded-lg p-5 space-y-5 shadow-[4px_4px_0_var(--color-brand)]">
    <label class="block">
      <span class="text-sm font-medium">Nombre *</span>
      <input
        type="text"
        name="name"
        required
        maxlength={MATERIAL_NAME_MAX}
        value={values.name ?? ""}
        placeholder="Ej: PLA, PETG, Argollas, Vasos milkshake, Cianocrilato"
        class={fieldClass}
      />
      {errorMsg("name") && <p class="text-xs text-red-600 mt-1">{errorMsg("name")}</p>}
    </label>

    <div>
      <span class="text-sm font-medium block mb-2">Tipo *</span>
      <div class="flex gap-2 flex-wrap">
        {MATERIAL_KIND_VALUES.map((k) => (
          <label class="cursor-pointer">
            <input
              type="radio"
              name="kind"
              value={k}
              checked={currentKind === k}
              class="sr-only peer"
              data-kind-radio
            />
            <span
              class="inline-block px-4 py-2 border-2 rounded-md text-sm font-medium transition-colors border-brand/30 text-brand peer-checked:bg-brand peer-checked:text-white peer-checked:border-brand hover:border-brand"
            >
              {MATERIAL_KIND_LABELS[k]}
            </span>
          </label>
        ))}
      </div>
      <p class="text-xs text-gray-500 mt-1">
        <strong>Filamento</strong>: la calculadora usa <strong>costo/kg × multiplicador del proceso</strong> por gramos impresos.
        <strong>Componente</strong>: la calculadora suma <strong>cantidad × precio venta</strong> directo.
        <strong>Adhesivo</strong> y <strong>Accesorio</strong>: no entran en la calculadora; se venden como insumos sueltos.
      </p>
      {errorMsg("kind") && <p class="text-xs text-red-600 mt-1">{errorMsg("kind")}</p>}
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <label class="block">
        <span class="text-sm font-medium">
          Precio <strong>costo</strong> (<span data-price-unit>{MATERIAL_KIND_UNIT[currentKind]}</span>) *
        </span>
        <input
          type="number"
          name="cost_price"
          required
          min="0"
          step="0.01"
          value={values.cost_price ?? 0}
          data-cost-price
          class={fieldClass}
        />
        <p class="text-xs text-gray-500 mt-1">Lo que pagás vos al proveedor.</p>
        {errorMsg("cost_price") && (
          <p class="text-xs text-red-600 mt-1">{errorMsg("cost_price")}</p>
        )}
      </label>

      <label class="block">
        <span class="text-sm font-medium">
          Precio <strong>venta</strong> (<span data-price-unit>{MATERIAL_KIND_UNIT[currentKind]}</span>) *
        </span>
        <input
          type="number"
          name="sell_price"
          required
          min="0"
          step="0.01"
          value={values.sell_price ?? 0}
          data-sell-price
          class={fieldClass}
        />
        <p class="text-xs text-gray-500 mt-1">
          Lo que cobrás. Margen: <span data-margin-display class="font-mono font-medium">—</span>
        </p>
        {errorMsg("sell_price") && (
          <p class="text-xs text-red-600 mt-1">{errorMsg("sell_price")}</p>
        )}
      </label>
    </div>

    <div>
      <span class="text-sm font-medium block">Colores</span>
      <p class="text-xs text-gray-500 mt-1 mb-2">
        Se usan para filtrar ventas de insumos. Agregá uno por uno, o varios separados por coma.
      </p>

      <div
        class="flex flex-wrap gap-2 mb-2 min-h-[2rem]"
        data-color-chips
        aria-live="polite"
      >
        {initialColors.map((c) => (
          <span
            class="inline-flex items-center gap-1.5 px-2 py-1 border-2 border-brand/30 rounded-md text-sm bg-white"
            data-color-chip={c}
          >
            <span
              class="inline-block w-4 h-4 rounded border border-brand/20 shrink-0"
              style={colorBg(c)}
              aria-hidden="true"
            ></span>
            <span>{c}</span>
            <button
              type="button"
              class="text-gray-400 hover:text-red-600 ml-1 leading-none cursor-pointer text-base font-bold"
              data-color-remove={c}
              aria-label={`Quitar ${c}`}
            >×</button>
          </span>
        ))}
        {initialColors.length === 0 && (
          <span class="text-xs text-gray-400 italic self-center" data-color-empty>
            Sin colores cargados.
          </span>
        )}
      </div>

      <input
        type="hidden"
        name="colors"
        data-colors-hidden
        value={initialColors.join(", ")}
      />

      <div class="flex gap-2">
        <input
          type="text"
          data-color-new
          placeholder="Ej: negro"
          maxlength={30}
          class={fieldClass + " mt-0 flex-1"}
        />
        <button
          type="button"
          data-color-add
          class="px-3 py-2 border-2 border-brand text-brand rounded-md text-sm font-medium hover:bg-brand hover:text-white transition-colors whitespace-nowrap"
        >
          + Agregar
        </button>
      </div>
    </div>

    <label class="inline-flex items-center gap-2 cursor-pointer">
      <input
        type="checkbox"
        name="active"
        checked={values.active ?? true}
        class="w-4 h-4 accent-accent"
      />
      <span class="text-sm font-medium">Activo (aparece en la calculadora)</span>
    </label>
  </div>

  <div class="flex flex-wrap items-center justify-between gap-3">
    <a
      href="/admin/materiales"
      class="text-sm text-gray-600 hover:text-brand underline-offset-4 hover:underline"
    >
      ← Volver al listado
    </a>

    <div class="flex items-center gap-3">
      {mode === "edit" && materialId && (
        <button
          type="submit"
          name="action"
          value="delete"
          formnovalidate
          data-confirm="¿Seguro que querés borrar este material? Esta acción no se puede deshacer."
          class="px-4 py-2 border-2 border-red-600 text-red-600 rounded-md hover:bg-red-600 hover:text-white transition-colors text-sm font-medium"
        >
          Eliminar
        </button>
      )}
      <button
        type="submit"
        name="action"
        value="save"
        class="px-5 py-2.5 bg-accent text-white rounded-md hover:bg-accent-hover transition-colors font-medium"
      >
        {mode === "create" ? "Crear material" : "Guardar cambios"}
      </button>
    </div>
  </div>
</form>

<script>
  const KIND_UNIT: Record<string, string> = {
    filament: "$/kg",
    component: "$/u",
    adhesive: "$/u",
    accessory: "$/u",
  };

  // Update unit labels (cost + sell) cuando cambia kind
  const unitEls = document.querySelectorAll<HTMLElement>("[data-price-unit]");
  document.querySelectorAll<HTMLInputElement>("[data-kind-radio]").forEach((radio) => {
    radio.addEventListener("change", () => {
      if (!radio.checked) return;
      unitEls.forEach((el) => {
        el.textContent = KIND_UNIT[radio.value] ?? "$";
      });
    });
  });

  // Margen calculado en vivo
  const costEl = document.querySelector<HTMLInputElement>("[data-cost-price]");
  const sellEl = document.querySelector<HTMLInputElement>("[data-sell-price]");
  const marginEl = document.querySelector<HTMLElement>("[data-margin-display]");

  function updateMargin() {
    if (!costEl || !sellEl || !marginEl) return;
    const cost = Number(costEl.value);
    const sell = Number(sellEl.value);
    if (!Number.isFinite(cost) || cost <= 0) {
      marginEl.textContent = "—";
      marginEl.className = "font-mono font-medium";
      return;
    }
    if (!Number.isFinite(sell)) {
      marginEl.textContent = "—";
      marginEl.className = "font-mono font-medium";
      return;
    }
    const margin = (sell - cost) / cost;
    const pct = (margin * 100).toFixed(0);
    marginEl.textContent = `${pct}%`;
    marginEl.className =
      "font-mono font-medium " +
      (margin > 0
        ? "text-emerald-700"
        : margin < 0
          ? "text-red-600"
          : "text-gray-500");
  }
  costEl?.addEventListener("input", updateMargin);
  sellEl?.addEventListener("input", updateMargin);
  updateMargin();

  // ─── Color chips ───
  // Hex map duplicado client-side. Incluye los colores del enum Color del
  // sistema (ver lib/types.ts) + extras comunes para materials (rosa,
  // marron, etc.) ya que el usuario puede tipear cualquier color libre.
  const CHIP_HEX: Record<string, string> = {
    blanco: "#ffffff",
    negro: "#1a1a1a",
    gris: "#9ca3af",
    azul: "#2563eb",
    rojo: "#dc2626",
    verde: "#16a34a",
    amarillo: "#facc15",
    naranja: "#f97316",
    morado: "#9333ea",
    transparente: "linear-gradient(45deg,#fff 0%,#f3f4f6 50%,#fff 100%)",
    celeste: "#7dd3fc",
    rosa: "#ec4899",
    marron: "#92400e",
    dorado: "#d4af37",
    plateado: "#c0c0c0",
    beige: "#f5deb3",
    turquesa: "#06b6d4",
    fucsia: "#d946ef",
  };

  function chipBg(c: string): string {
    const hex = CHIP_HEX[c];
    if (hex && hex.startsWith("linear")) return `background: ${hex}`;
    if (hex) return `background-color: ${hex}`;
    return "background: repeating-conic-gradient(#e5e7eb 0 25%, transparent 0 50%) 50% / 8px 8px";
  }

  const chipsContainer = document.querySelector<HTMLElement>("[data-color-chips]");
  const hiddenInput = document.querySelector<HTMLInputElement>("[data-colors-hidden]");
  const newInput = document.querySelector<HTMLInputElement>("[data-color-new]");
  const addBtn = document.querySelector<HTMLButtonElement>("[data-color-add]");

  if (chipsContainer && hiddenInput && newInput && addBtn) {
    let colors: string[] = (hiddenInput.value || "")
      .split(",")
      .map((c) => c.trim().toLowerCase())
      .filter(Boolean);

    function render() {
      chipsContainer!.replaceChildren();

      if (colors.length === 0) {
        const empty = document.createElement("span");
        empty.className = "text-xs text-gray-400 italic self-center";
        empty.textContent = "Sin colores cargados.";
        chipsContainer!.appendChild(empty);
        hiddenInput!.value = "";
        return;
      }

      for (const c of colors) {
        const chip = document.createElement("span");
        chip.className =
          "inline-flex items-center gap-1.5 px-2 py-1 border-2 border-brand/30 rounded-md text-sm bg-white";

        const swatch = document.createElement("span");
        swatch.className = "inline-block w-4 h-4 rounded border border-brand/20 shrink-0";
        swatch.setAttribute("aria-hidden", "true");
        swatch.style.cssText = chipBg(c);

        const name = document.createElement("span");
        name.textContent = c;

        const removeBtn = document.createElement("button");
        removeBtn.type = "button";
        removeBtn.className =
          "text-gray-400 hover:text-red-600 ml-1 leading-none cursor-pointer text-base font-bold";
        removeBtn.setAttribute("aria-label", `Quitar ${c}`);
        removeBtn.textContent = "×";
        removeBtn.addEventListener("click", () => {
          colors = colors.filter((x) => x !== c);
          render();
        });

        chip.append(swatch, name, removeBtn);
        chipsContainer!.appendChild(chip);
      }

      hiddenInput!.value = colors.join(", ");
    }

    function addFromInput() {
      const raw = newInput!.value;
      if (!raw.trim()) return;
      const toAdd = raw
        .split(",")
        .map((c) => c.trim().toLowerCase())
        .filter(Boolean);
      let added = false;
      for (const c of toAdd) {
        if (c.length > 30) continue;
        if (!colors.includes(c)) {
          colors.push(c);
          added = true;
        }
      }
      newInput!.value = "";
      if (added) render();
    }

    addBtn.addEventListener("click", addFromInput);
    newInput.addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        e.preventDefault();
        addFromInput();
      }
    });

    // Render inicial — reemplaza los chips SSR para que toda la UI viva del
    // mismo estado JS (evita drift entre lo renderizado y lo manipulable).
    render();
  }

  // Confirm dialogs handled globally in AdminLayout
</script>
