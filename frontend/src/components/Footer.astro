---
import { getCategories } from "../lib/pocketbase";

const categories = await getCategories();

const whatsappPhone = import.meta.env.PUBLIC_WHATSAPP_NUMBER || "5493816563940";
const whatsappMessage = encodeURIComponent("¡Hola Print All! 👋");
const whatsappUrl = `https://wa.me/${whatsappPhone}?text=${whatsappMessage}`;

const navLinks = [
  { href: "/", label: "Inicio" },
  { href: "/productos", label: "Productos" },
  { href: "/contacto", label: "Contacto" },
];

const year = new Date().getFullYear();
---

<footer class="site-footer relative bg-brand text-white/55 pt-24 overflow-hidden">
  <!-- Border top: gradiente accent visible — separa visualmente del contenido anterior cuando ambos son dark -->
  <div class="absolute inset-x-0 top-0 h-[2px] bg-gradient-to-r from-transparent via-accent to-transparent"></div>

  <!-- Capa: dot grid sutil -->
  <div class="footer-dotgrid absolute inset-0 pointer-events-none"></div>

  <!-- Capa: blob ambiental -->
  <div class="absolute -top-32 right-0 h-72 w-72 rounded-full bg-accent blur-3xl opacity-[0.07] pointer-events-none"></div>

  <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <!-- Grid principal: 3 columnas -->
    <div class="grid grid-cols-1 gap-10 py-14 sm:grid-cols-2 lg:grid-cols-12 sm:gap-8 sm:py-16">
      <!-- Brand -->
      <div class="lg:col-span-5">
        <a href="/" class="inline-flex items-center group" aria-label="Print All — Inicio">
          <img
            src="/logo.webp"
            alt="Print All"
            class="h-10 w-auto transition-transform duration-300 group-hover:rotate-[-2deg]"
            width="146"
            height="90"
          />
        </a>
        <p class="mt-4 text-sm leading-relaxed max-w-sm text-white/50">
          Impresión 3D personalizada en Aguilares, Tucumán. Filamentos premium,
          productos únicos y todo lo que imaginás hecho realidad.
        </p>
        <div class="mt-5 flex items-center gap-2 text-xs">
          <span class="inline-flex items-center gap-1.5 rounded-full bg-white/[0.04] border border-white/10 px-2.5 py-1 text-white/60">
            <span class="relative flex h-1.5 w-1.5">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
              <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
            </span>
            Tomamos pedidos
          </span>
        </div>
      </div>

      <!-- Catálogo -->
      <div class="lg:col-span-3">
        <h3 class="font-display text-sm uppercase tracking-[0.2em] text-white mb-4">Catálogo</h3>
        <ul class="space-y-2">
          {
            categories.slice(0, 6).map((cat) => (
              <li>
                <a
                  href={`/?categoria=${cat.slug}`}
                  class="group inline-flex items-center gap-2 text-sm text-white/55 hover:text-accent transition-colors"
                >
                  <span class="text-base leading-none opacity-70 group-hover:opacity-100 transition-opacity">{cat.icon}</span>
                  <span>{cat.name}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Contacto + Navegación -->
      <div class="lg:col-span-4">
        <h3 class="font-display text-sm uppercase tracking-[0.2em] text-white mb-4">Hablemos</h3>
        <ul class="space-y-3">
          <li>
            <a
              href={whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="group inline-flex items-center gap-2.5 text-sm text-white/65 hover:text-accent transition-colors"
            >
              <span class="grid place-items-center h-7 w-7 rounded-full bg-white/[0.04] border border-white/10 group-hover:border-accent/40 group-hover:bg-accent/10 transition-colors">
                <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
              </span>
              <span class="font-medium">WhatsApp</span>
            </a>
          </li>
          <li>
            <a
              href="https://www.instagram.com/printall.tuc/"
              target="_blank"
              rel="noopener noreferrer"
              class="group inline-flex items-center gap-2.5 text-sm text-white/65 hover:text-accent transition-colors"
            >
              <span class="grid place-items-center h-7 w-7 rounded-full bg-white/[0.04] border border-white/10 group-hover:border-accent/40 group-hover:bg-accent/10 transition-colors">
                <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
              </span>
              <span class="font-medium">@printall.tuc</span>
            </a>
          </li>
          <li>
            <div class="inline-flex items-center gap-2.5 text-sm text-white/55">
              <span class="grid place-items-center h-7 w-7 rounded-full bg-white/[0.04] border border-white/10">
                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </span>
              <span>Aguilares, Tucumán</span>
            </div>
          </li>
        </ul>

        <!-- Mini-nav adicional -->
        <div class="mt-6 pt-5 border-t border-white/5">
          <ul class="flex flex-wrap gap-x-4 gap-y-2 text-[11px] uppercase tracking-[0.16em] font-bold">
            {
              navLinks.map((link) => (
                <li>
                  <a href={link.href} class="text-white/40 hover:text-white transition-colors">
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>

    <!-- Strip inferior: copyright + tagline + back to top -->
    <div class="border-t border-white/5 py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs">
      <p class="text-white/35 flex items-center gap-2">
        <span>© {year} Print All</span>
        <span class="text-white/15">·</span>
        <span>Hecho con <span class="text-accent">♥</span> en Tucumán</span>
      </p>
      <button
        type="button"
        data-back-to-top
        class="group inline-flex items-center gap-1.5 text-white/40 hover:text-accent transition-colors uppercase tracking-[0.18em] font-bold cursor-pointer"
        aria-label="Volver arriba"
      >
        <span>Volver arriba</span>
        <svg class="h-3.5 w-3.5 transition-transform duration-200 group-hover:-translate-y-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
        </svg>
      </button>
    </div>
  </div>
</footer>

<style>
  .footer-dotgrid {
    background-image: radial-gradient(rgba(255, 255, 255, 0.28) 1px, transparent 1px);
    background-size: 22px 22px;
    opacity: 0.06;
    mask-image: linear-gradient(to bottom, black, transparent 90%);
    -webkit-mask-image: linear-gradient(to bottom, black, transparent 90%);
  }
</style>

<script>
  const btn = document.querySelector("[data-back-to-top]") as HTMLButtonElement | null;
  btn?.addEventListener("click", () => {
    window.scrollTo({ top: 0, behavior: "smooth" });
  });
</script>
