---
import type { ProductWithCategory } from "../lib/types";
import { STOCK_LABELS, STOCK_COLORS } from "../lib/types";
import { getProductWhatsAppUrl } from "../lib/pocketbase";

interface Props {
  product: ProductWithCategory;
}

const { product } = Astro.props;
const firstImage = product.images?.[0];
const imageSrc = firstImage?.thumbnails?.["400x400"] ?? "/logo.png";
const category = product.expand?.category;

const stockColor = STOCK_COLORS[product.stock_status] ?? "bg-gray-400";
const stockLabel = STOCK_LABELS[product.stock_status] ?? product.stock_status;
const whatsappUrl = getProductWhatsAppUrl(product);
---

<div
  class="group relative rounded-xl bg-surface border border-surface overflow-hidden hover:border-accent/20 hover:shadow-lg hover:shadow-brand/5 transition-all duration-300 hover:-translate-y-1"
>
  <!-- Imagen (link al detalle) -->
  <div class="relative">
    <a href={`/producto/${product.slug}`} class="block">
      <div class="aspect-square overflow-hidden bg-brand/5">
        {firstImage ? (
          <img
            src={imageSrc}
            alt={product.name}
            loading="lazy"
            decoding="async"
            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
            width="400"
            height="400"
          />
        ) : (
          <div class="flex h-full w-full items-center justify-center text-brand/20">
            <svg class="h-16 w-16" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z" />
            </svg>
          </div>
        )}
      </div>
    </a>

    <!-- Badge de stock -->
    <div
      class="absolute top-2.5 left-2.5 flex items-center gap-1 rounded-full bg-white/90 backdrop-blur-sm px-2 py-0.5 shadow-xs"
      title={stockLabel}
    >
      <span class={`inline-block h-2 w-2 rounded-full ${stockColor}`}></span>
      <span class="text-[10px] font-semibold text-brand/70">{stockLabel}</span>
    </div>

    <!-- Badge destacado -->
    {product.featured && (
      <span class="absolute top-2.5 right-2.5 text-[10px] font-bold uppercase tracking-wider text-accent bg-accent-soft/90 backdrop-blur-sm rounded-full px-2 py-0.5">
        Destacado
      </span>
    )}

    <!-- Botón WhatsApp directo (aparece en hover) -->
    <a
      href={whatsappUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="absolute bottom-2 right-2 z-10 opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0 transition-all duration-300 bg-accent hover:bg-accent-hover text-white rounded-full px-3 py-1.5 text-xs font-semibold flex items-center gap-1.5 shadow-lg shadow-accent/20"
    >
      <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      Consultar
    </a>
  </div>

  <!-- Info (link al detalle) -->
  <a href={`/producto/${product.slug}`} class="block p-4">
    <div class="flex items-start justify-between gap-2 mb-1">
      <h3 class="font-semibold text-sm leading-tight text-text line-clamp-2 group-hover:text-accent transition-colors">
        {product.name}
      </h3>
    </div>

    {category && (
      <p class="text-xs text-brand/40 mb-2.5">
        {category.icon} {category.name}
      </p>
    )}

    <div class="flex items-center justify-between border-t border-brand/5 pt-2.5 mt-auto">
      <span class="text-sm font-bold text-text">
        {product.price_label ||
          (product.price
            ? `$${product.price.toLocaleString("es-AR")}`
            : "Consultar")}
      </span>
      <div
        class="h-8 w-8 rounded-full bg-accent/10 flex items-center justify-center text-accent opacity-0 group-hover:opacity-100 transition-all duration-300 translate-x-2 group-hover:translate-x-0"
      >
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </div>
    </div>
  </a>
</div>
