---
import type { ProductWithCategory } from "../lib/types";

interface Props {
  product: ProductWithCategory;
}

const { product } = Astro.props;
const firstImage = product.images?.[0];
const imageSrc = firstImage?.thumbnails?.["400x400"] ?? "/logo.png";
const category = product.expand?.category;
---

<a
  href={`/producto/${product.slug}`}
  class="group block rounded-xl bg-surface border border-surface overflow-hidden hover:border-accent/20 hover:shadow-lg hover:shadow-brand/5 transition-all duration-300 hover:-translate-y-1"
>
  <div class="aspect-square overflow-hidden bg-brand/5">
    {firstImage ? (
      <img
        src={imageSrc}
        alt={product.name}
        loading="lazy"
        decoding="async"
        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
        width="400"
        height="400"
      />
    ) : (
      <div class="flex h-full w-full items-center justify-center text-brand/20">
        <svg class="h-16 w-16" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z" />
        </svg>
      </div>
    )}
  </div>

  <div class="p-4">
    <div class="flex items-start justify-between gap-2 mb-1.5">
      <h3 class="font-semibold text-sm leading-tight text-text line-clamp-2 group-hover:text-accent transition-colors">
        {product.name}
      </h3>
      {
        product.featured && (
          <span class="shrink-0 text-[10px] font-bold uppercase tracking-wider text-accent bg-accent-soft rounded-full px-2 py-0.5">
            Destacado
          </span>
        )
      }
    </div>

    {category && (
      <p class="text-xs text-brand/40 mb-2">{category.name}</p>
    )}

    <div class="flex items-center justify-between mt-3">
      <span class="text-sm font-bold text-text">
        {product.price_label || (product.price ? `$${product.price.toLocaleString("es-AR")}` : "Consultar")}
      </span>
      <div class="h-8 w-8 rounded-full bg-accent flex items-center justify-center text-white opacity-0 group-hover:opacity-100 transition-all duration-300 translate-x-2 group-hover:translate-x-0">
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </div>
    </div>
  </div>
</a>
