---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}
const { title, description, ogImage } = Astro.props;
const fullTitle = `${title} | Print All`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description || "Catálogo online de Print All — impresión 3D en Aguilares, Tucumán. Filamentos, mates, vasos, llaveros y más."} />

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description || "Impresión 3D en Aguilares, Tucumán."} />
    <meta property="og:type" content="website" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/png" href="/logo.png" />
  </head>
  <body class="bg-[#FAFAF9] text-[#17171E] font-sans antialiased">
    <Header />
    <main class="min-h-[60vh]">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  @import "../assets/styles/global.css";

  @theme {
    --font-display: "Archivo Black", sans-serif;
    --font-sans: "DM Sans", sans-serif;
    --color-brand: #1f1f2b;
    --color-surface: #f3f0eb;
    --color-accent: #ea580c;
    --color-accent-hover: #c2410c;
    --color-accent-soft: #fff7ed;
    --color-text: #17171e;
  }

  html {
    scroll-behavior: smooth;
  }

  ::selection {
    background-color: var(--color-accent);
    color: white;
  }
</style>
