# Dependencies
node_modules/
.pnpm-store/

# Build output
frontend/dist/
frontend/.astro/

# Env (solo .env.example se commitea)
.env
.env.*
!.env.example

# PocketBase data (NUNCA commitear — son los datos reales de prod/dev)
pocketbase/pb_data/
pocketbase/pb_migrations_backup/

# Defensa contra contaminación de pb_migrations (PB ejecuta TODOS los archivos del dir;
# solo deben commitearse los .js de migrations, ver pocketbase-037-quirks en memoria)
pocketbase/pb_migrations/*.db
pocketbase/pb_migrations/*.db-shm
pocketbase/pb_migrations/*.db-wal
pocketbase/pb_migrations/*.d.ts

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Editor
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Cloudflared (credenciales del túnel)
cloudflared/*.json
cloudflared/cert.pem

# Autoskills (skills-lock.json SI se commitea)
frontend/.agents/
frontend/.claude/

# PocketBase data backups
pocketbase/pb_data_backup*

# Playwright artifacts
frontend/test-results/
frontend/playwright-report/
frontend/blob-report/
frontend/playwright/.cache/
