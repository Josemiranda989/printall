# Variables que docker-compose sustituye en docker-compose.yml
# Copiá este archivo a .env y completá los valores reales para tu deployment.

# URL pública de PocketBase (la que ve el browser, se inlina en el frontend)
PUBLIC_POCKETBASE_URL=https://your-pocketbase-domain.com

# Número de WhatsApp del negocio (formato internacional, sin + ni espacios)
PUBLIC_WHATSAPP_NUMBER=5490000000000

# Sentry error tracking (opcional). Sin SENTRY_DSN, Sentry queda deshabilitado
# y no se carga la integration ni en build ni en runtime (no-op).
# El DSN se obtiene en https://sentry.io -> settings -> projects -> [proyecto] -> Client Keys (DSN)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
